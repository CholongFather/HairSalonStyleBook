@inherits LayoutComponentBase
@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IDisposable

<div class="salon-app">
    <Header />
    <RibbonDivider />
    <main class="salon-content">
        <div class="page-slide-container">
            <div class="page-transition @_animClass">
                <ErrorBoundary @ref="_errorBoundary">
                    <ChildContent>
                        @Body
                    </ChildContent>
                    <ErrorContent>
                        <div class="error-boundary-container">
                            <div class="error-boundary-card">
                                <i class="bi bi-exclamation-triangle"></i>
                                <h3>문제가 발생했습니다</h3>
                                <p>페이지를 다시 불러와 주세요.</p>
                                <button class="btn btn-salon" @onclick="RecoverFromError">
                                    <i class="bi bi-arrow-clockwise"></i> 새로고침
                                </button>
                            </div>
                        </div>
                    </ErrorContent>
                </ErrorBoundary>
            </div>
        </div>
    </main>
    <Footer />
</div>

<!-- 맨 위로 버튼 -->
<button class="btn-scroll-top" @onclick="ScrollToTop">
    <i class="bi bi-chevron-up"></i>
</button>

@code {
    private ErrorBoundary? _errorBoundary;
    private string _animClass = "page-enter";
    protected override void OnInitialized()
    {
        Nav.LocationChanged += OnLocationChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("salonApp.initScrollAndIdle");
        }
    }

    private async Task ScrollToTop()
    {
        await JS.InvokeVoidAsync("salonApp.scrollToTop");
    }

    private async void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        try
        {
            // 나가는 애니메이션
            _animClass = "page-exit";
            await InvokeAsync(StateHasChanged);

            // 짧은 딜레이 후 들어오는 애니메이션
            await Task.Delay(250);
            _animClass = "page-enter";
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[MainLayout] 페이지 전환 애니메이션 오류: {ex.Message}");
        }
    }

    private void RecoverFromError()
    {
        _errorBoundary?.Recover();
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
    }
}

<style>
    .page-slide-container {
        overflow: hidden;
    }

    .page-transition {
        animation-fill-mode: both;
        animation-timing-function: cubic-bezier(0.25, 0.46, 0.45, 0.94);
        position: relative;
    }

    .page-enter {
        animation: fadeIn 0.3s ease;
    }

    .page-exit {
        animation: fadeOut 0.2s ease;
    }

    @@keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }

    @@keyframes fadeOut {
        from { opacity: 1; }
        to { opacity: 0; }
    }

    /* 맨 위로 버튼 */
    .btn-scroll-top {
        position: fixed;
        bottom: 2rem;
        right: 1.2rem;
        width: 44px;
        height: 44px;
        border-radius: 50%;
        border: 1px solid var(--salon-light-gray);
        background: var(--salon-white);
        color: var(--salon-dark);
        font-size: 1.1rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 3px 12px rgba(0, 0, 0, 0.1);
        opacity: 0;
        transform: translateY(10px);
        pointer-events: none;
        transition: all 0.3s ease;
        z-index: 100;
    }

    .btn-scroll-top.visible {
        opacity: 1;
        transform: translateY(0);
        pointer-events: auto;
    }

    .btn-scroll-top:hover {
        background: var(--salon-green);
        color: #fff;
        border-color: var(--salon-green);
    }

    .btn-scroll-top:active {
        transform: scale(0.95);
    }

    /* ErrorBoundary */
    .error-boundary-container {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 60vh;
        padding: 2rem;
    }

    .error-boundary-card {
        text-align: center;
        padding: 2.5rem;
        border-radius: 16px;
        background: var(--salon-white);
        border: 1px solid var(--salon-light-gray);
        max-width: 360px;
    }

    .error-boundary-card i {
        font-size: 2.5rem;
        color: var(--salon-accent);
        margin-bottom: 1rem;
    }

    .error-boundary-card h3 {
        font-family: var(--font-serif);
        font-size: 1.1rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
        color: var(--salon-black);
    }

    .error-boundary-card p {
        font-family: var(--font-serif);
        font-size: 0.85rem;
        color: var(--salon-gray);
        margin-bottom: 1.2rem;
    }

    /* 태블릿 반응형 */
    @@media (min-width: 768px) {
        .btn-scroll-top {
            width: 52px;
            height: 52px;
            font-size: 1.3rem;
            bottom: 2.5rem;
            right: 1.5rem;
        }
    }
</style>
