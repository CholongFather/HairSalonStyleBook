@inject IJSRuntime JS

<div class="rich-editor">
    <div class="rich-toolbar">
        <button type="button" class="toolbar-btn" title="굵게" @onclick='() => ExecCommand("bold")'>
            <i class="bi bi-type-bold"></i>
        </button>
        <button type="button" class="toolbar-btn" title="기울임" @onclick='() => ExecCommand("italic")'>
            <i class="bi bi-type-italic"></i>
        </button>
        <button type="button" class="toolbar-btn" title="밑줄" @onclick='() => ExecCommand("underline")'>
            <i class="bi bi-type-underline"></i>
        </button>
        <span class="toolbar-divider"></span>
        <button type="button" class="toolbar-btn" title="소제목" @onclick="InsertHeading">
            <i class="bi bi-type-h2"></i>
        </button>
        <button type="button" class="toolbar-btn" title="구분선" @onclick='() => ExecCommand("insertHorizontalRule")'>
            <i class="bi bi-dash-lg"></i>
        </button>
        <span class="toolbar-divider"></span>
        <button type="button" class="toolbar-btn" title="글머리 기호" @onclick='() => ExecCommand("insertUnorderedList")'>
            <i class="bi bi-list-ul"></i>
        </button>
        <button type="button" class="toolbar-btn" title="번호 목록" @onclick='() => ExecCommand("insertOrderedList")'>
            <i class="bi bi-list-ol"></i>
        </button>
        <span class="toolbar-divider"></span>
        <button type="button" class="toolbar-btn" title="서식 제거" @onclick='() => ExecCommand("removeFormat")'>
            <i class="bi bi-eraser"></i>
        </button>
        <span class="toolbar-divider"></span>
        <button type="button" class="toolbar-btn toolbar-icon-toggle @(_showIconPalette ? "active" : "")" title="아이콘 삽입" @onclick="ToggleIconPalette">
            <i class="bi bi-scissors"></i> <small>▾</small>
        </button>
    </div>
    @if (_showIconPalette)
    {
        <div class="icon-palette">
            <div class="icon-palette-group">
                <span class="icon-palette-label">시술</span>
                <button type="button" class="icon-btn" title="가위" @onclick='() => InsertIcon("✂️")'>✂️</button>
                <button type="button" class="icon-btn" title="헤어컷" @onclick='() => InsertIcon("💇‍♀️")'>💇‍♀️</button>
                <button type="button" class="icon-btn" title="이발소" @onclick='() => InsertIcon("💈")'>💈</button>
                <button type="button" class="icon-btn" title="빗" @onclick='() => InsertIcon("🪮")'>🪮</button>
                <button type="button" class="icon-btn" title="헤드스파" @onclick='() => InsertIcon("💆‍♀️")'>💆‍♀️</button>
                <button type="button" class="icon-btn" title="물방울" @onclick='() => InsertIcon("💧")'>💧</button>
                <button type="button" class="icon-btn" title="팔레트" @onclick='() => InsertIcon("🎨")'>🎨</button>
            </div>
            <div class="icon-palette-group">
                <span class="icon-palette-label">장식</span>
                <button type="button" class="icon-btn" title="반짝이" @onclick='() => InsertIcon("✨")'>✨</button>
                <button type="button" class="icon-btn" title="별" @onclick='() => InsertIcon("⭐")'>⭐</button>
                <button type="button" class="icon-btn" title="하트" @onclick='() => InsertIcon("💖")'>💖</button>
                <button type="button" class="icon-btn" title="꽃" @onclick='() => InsertIcon("🌸")'>🌸</button>
                <button type="button" class="icon-btn" title="리본" @onclick='() => InsertIcon("🎀")'>🎀</button>
                <button type="button" class="icon-btn" title="왕관" @onclick='() => InsertIcon("👑")'>👑</button>
                <button type="button" class="icon-btn" title="보석" @onclick='() => InsertIcon("💎")'>💎</button>
            </div>
            <div class="icon-palette-group">
                <span class="icon-palette-label">포인트</span>
                <button type="button" class="icon-btn" title="체크" @onclick='() => InsertIcon("✅")'>✅</button>
                <button type="button" class="icon-btn" title="포인트" @onclick='() => InsertIcon("👉")'>👉</button>
                <button type="button" class="icon-btn" title="추천" @onclick='() => InsertIcon("👍")'>👍</button>
                <button type="button" class="icon-btn" title="불꽃" @onclick='() => InsertIcon("🔥")'>🔥</button>
                <button type="button" class="icon-btn" title="100점" @onclick='() => InsertIcon("💯")'>💯</button>
                <button type="button" class="icon-btn" title="전구" @onclick='() => InsertIcon("💡")'>💡</button>
                <button type="button" class="icon-btn" title="메모" @onclick='() => InsertIcon("📝")'>📝</button>
            </div>
        </div>
    }
    <div id="@_editorId"
         class="rich-content"
         contenteditable="true"
         @onfocusout="OnContentChanged">
    </div>
</div>

@code {
    [Parameter] public string Value { get; set; } = "";
    [Parameter] public EventCallback<string> ValueChanged { get; set; }

    private string _editorId = $"editor-{Guid.NewGuid():N}"[..14];
    private bool _initialized;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("salonApp.richEditor.setHtml", _editorId, Value ?? "");
            _initialized = true;
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_initialized)
        {
            var currentHtml = await JS.InvokeAsync<string>("salonApp.richEditor.getHtml", _editorId);
            if (currentHtml != Value)
            {
                await JS.InvokeVoidAsync("salonApp.richEditor.setHtml", _editorId, Value ?? "");
            }
        }
    }

    private async Task ExecCommand(string command)
    {
        await JS.InvokeVoidAsync("salonApp.richEditor.execCommand", _editorId, command, null);
    }

    private async Task InsertHeading()
    {
        await JS.InvokeVoidAsync("salonApp.richEditor.execCommand", _editorId, "formatBlock", "h3");
    }

    private bool _showIconPalette;

    private void ToggleIconPalette()
    {
        _showIconPalette = !_showIconPalette;
    }

    private async Task InsertIcon(string icon)
    {
        await JS.InvokeVoidAsync("salonApp.richEditor.insertText", _editorId, icon + " ");
    }

    private async Task OnContentChanged()
    {
        var html = await JS.InvokeAsync<string>("salonApp.richEditor.getHtml", _editorId);
        if (html != Value)
        {
            await ValueChanged.InvokeAsync(html);
        }
    }
}

<style>
    .rich-editor {
        border: 1px solid var(--salon-light-gray);
        border-radius: 4px;
        overflow: hidden;
    }

    .rich-toolbar {
        display: flex;
        align-items: center;
        gap: 2px;
        padding: 0.4rem 0.5rem;
        background: #f8f8f6;
        border-bottom: 1px solid var(--salon-light-gray);
        flex-wrap: wrap;
    }

    .toolbar-btn {
        background: none;
        border: 1px solid transparent;
        border-radius: 4px;
        padding: 0.3rem 0.5rem;
        cursor: pointer;
        color: var(--salon-dark, #333);
        font-size: 0.9rem;
        line-height: 1;
        transition: all 0.15s ease;
    }

    .toolbar-btn:hover {
        background: rgba(123, 163, 131, 0.15);
        border-color: var(--salon-green);
        color: var(--salon-green);
    }

    .toolbar-btn:active {
        background: rgba(123, 163, 131, 0.3);
    }

    .toolbar-divider {
        width: 1px;
        height: 1.2rem;
        background: var(--salon-light-gray);
        margin: 0 0.3rem;
    }

    .rich-content {
        min-height: 180px;
        max-height: 400px;
        overflow-y: auto;
        padding: 0.75rem;
        font-family: var(--font-serif);
        font-size: 0.85rem;
        line-height: 1.8;
        color: var(--salon-dark, #333);
        outline: none;
    }

    .rich-content:focus {
        box-shadow: inset 0 0 0 2px rgba(123, 163, 131, 0.15);
    }

    .rich-content h3 {
        font-size: 1rem;
        font-weight: 700;
        margin: 0.5rem 0;
        color: var(--salon-black);
    }

    .rich-content ul, .rich-content ol {
        padding-left: 1.5rem;
        margin: 0.5rem 0;
    }

    .rich-content hr {
        border: none;
        border-top: 1px solid var(--salon-light-gray);
        margin: 0.75rem 0;
    }

    .rich-content b, .rich-content strong {
        font-weight: 700;
    }

    /* 아이콘 팔레트 토글 */
    .toolbar-icon-toggle.active {
        background: rgba(123, 163, 131, 0.2);
        border-color: var(--salon-green);
        color: var(--salon-green);
    }

    .toolbar-icon-toggle small {
        font-size: 0.55rem;
        margin-left: -2px;
    }

    /* 아이콘 팔레트 */
    .icon-palette {
        padding: 0.5rem;
        background: #fafaf8;
        border-bottom: 1px solid var(--salon-light-gray);
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
    }

    .icon-palette-group {
        display: flex;
        align-items: center;
        gap: 2px;
        flex-wrap: wrap;
    }

    .icon-palette-label {
        font-family: var(--font-serif);
        font-size: 0.65rem;
        color: var(--salon-gray);
        min-width: 2.5rem;
        font-weight: 600;
    }

    .icon-btn {
        background: none;
        border: 1px solid transparent;
        border-radius: 4px;
        padding: 0.25rem 0.35rem;
        cursor: pointer;
        font-size: 1.1rem;
        line-height: 1;
        transition: all 0.15s ease;
    }

    .icon-btn:hover {
        background: rgba(123, 163, 131, 0.12);
        border-color: var(--salon-light-gray);
        transform: scale(1.15);
    }

    .icon-btn:active {
        transform: scale(0.95);
    }
</style>
