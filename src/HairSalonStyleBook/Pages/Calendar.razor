    public void OnKeyUndo()
    {
        Undo();
    }

    [JSInvokable]
    public void OnKeyDuplicate()
    {
        if (_selectedElementId == null) return;
        var elem = _data.FreeElements.FirstOrDefault(e => e.Id == _selectedElementId);
        if (elem != null) DuplicateElement(elem);
    }

    // -- 셀 데코 복사/붙여넣기 --
    private void CopyCellDeco(string dayStr)
    {
        if (!_data.CellDecos.TryGetValue(dayStr, out var cell)) return;
        _copiedCellDeco = new CalendarCellDeco
        {
            BackgroundColor = cell.BackgroundColor,
            Memo = cell.Memo,
            TextColor = cell.TextColor,
            Stickers = new List<string>(cell.Stickers),
        };
        StateHasChanged();
    }

    private void PasteCellDeco(string dayStr)
    {
        if (_copiedCellDeco == null) return;
        PushUndo();
        _data.CellDecos[dayStr] = new CalendarCellDeco
        {
            BackgroundColor = _copiedCellDeco.BackgroundColor,
            Memo = _copiedCellDeco.Memo,
            TextColor = _copiedCellDeco.TextColor,
            Stickers = new List<string>(_copiedCellDeco.Stickers),
        };
        StateHasChanged();
    }

    // -- D-Day 텍스트 계산 --
    private string GetDDayText(int day)
    {
        try
        {
            var targetDate = new DateTime(_data.Year, _data.Month, day);
            var today = DateTime.Today;
            var diff = (targetDate - today).Days;
            return diff switch
            {
                0 => "D-Day",
                > 0 => $"D-{diff}",
                < 0 => $"D+{Math.Abs(diff)}"
            };
        }
        catch { return ""; }
    }

    // -- 자동 꾸미기 --
    private enum AutoDecoStyle { Cute, Elegant, Salon, Nature, Party }

    private void AutoDecorate(AutoDecoStyle style)
    {
        PushUndo();

        var (emojis, svgs, bg, pattern) = style switch
        {
            AutoDecoStyle.Cute => (
                new[] { "💖", "🌸", "🎀", "✨", "🐱", "🌷", "💕", "🫶" },
                new[] { "heart", "flower", "star" },
                "#fff0f5", "hearts"),
            AutoDecoStyle.Elegant => (
                new[] { "✨", "💎", "👑", "🌙", "⭐", "💜" },
                new[] { "mirror", "star", "flower" },
                "#ede7f6", "dots"),
            AutoDecoStyle.Salon => (
                new[] { "✂️", "💇‍♀️", "💈", "🪮", "✨" },
                new[] { "scissors", "dryer", "comb", "brush", "mirror", "spray" },
                "#fffdf7", "none"),
            AutoDecoStyle.Nature => (
                new[] { "🌿", "🌻", "🍂", "🌈", "☕", "🌼" },
                new[] { "flower" },
                "#e8f5e9", "grid"),
            AutoDecoStyle.Party => (
                new[] { "🎉", "🎂", "🎁", "🔥", "🎵", "💰", "🌈" },
                new[] { "heart", "star" },
                "#fff8e1", "stars"),
            _ => (Array.Empty<string>(), Array.Empty<string>(), "#fffdf7", "none")
        };

        // 배경 적용
        _data.BackgroundColor = bg;
        _data.BackgroundPattern = pattern;

        // 이모지 5~8개 랜덤 배치
        var rng = Random.Shared;
        var count = rng.Next(5, Math.Min(9, 51 - _data.FreeElements.Count));
        for (var i = 0; i < count && _data.FreeElements.Count < 50; i++)
        {
            _data.FreeElements.Add(new CalendarFreeElement
            {
                Type = "emoji",
                Content = emojis[rng.Next(emojis.Length)],
                X = rng.Next(5, 95),
                Y = rng.Next(5, 95),
                Scale = 0.8 + rng.NextDouble() * 0.8,
                Rotation = rng.Next(-15, 15),
                ZIndex = _data.FreeElements.Count + 1,
            });
        }

        // SVG 2~3개 배치
        var svgCount = rng.Next(2, Math.Min(4, 51 - _data.FreeElements.Count));
        for (var i = 0; i < svgCount && _data.FreeElements.Count < 50; i++)
        {
            _data.FreeElements.Add(new CalendarFreeElement
            {
                Type = "svg",
                Content = svgs[rng.Next(svgs.Length)],
                X = rng.Next(5, 95),
                Y = rng.Next(5, 95),
                Scale = 1.0 + rng.NextDouble() * 1.0,
                Rotation = rng.Next(-10, 10),
                Opacity = 0.5 + rng.NextDouble() * 0.5,
                ZIndex = _data.FreeElements.Count + 1,
            });
        }

        // 와시테이프 1~2개
        var washiCount = rng.Next(1, Math.Min(3, 51 - _data.FreeElements.Count));
        var washiKeys = new[] { "stripe", "dot", "floral", "pastel" };
        for (var i = 0; i < washiCount && _data.FreeElements.Count < 50; i++)
        {
            _data.FreeElements.Add(new CalendarFreeElement
            {
                Type = "washi",
                Pattern = washiKeys[rng.Next(washiKeys.Length)],
                Width = rng.Next(80, 200),
                X = rng.Next(10, 90),
                Y = rng.Next(10, 90),
                Rotation = rng.Next(-12, 12),
                ZIndex = _data.FreeElements.Count + 1,
            });
        }

        StateHasChanged();
    }

    // -- 포맷 헬퍼 --
    private static string FPct(double v) => $"{v:F1}%";
    private static string FDeg(double v) => $"{v:F0}deg";
    private static string FScl(double v) => v.ToString("F2", System.Globalization.CultureInfo.InvariantCulture);
    private static string FPx(double v) => $"{v:F0}px";

    private string GetPatternStyle() => CalendarPatterns.GetPatternCss(_data.BackgroundPattern);

    private static MarkupString GetSvgSticker(string key) => SvgStickerLibrary.GetSvg(key);
}

