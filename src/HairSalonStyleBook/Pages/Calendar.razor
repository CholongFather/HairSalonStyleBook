@page "/calendar"
@attribute [Authorize(Roles = "Admin")]
@using Microsoft.AspNetCore.Authorization
@inject ICalendarDecoService CalendarService
@inject IAuthService AuthService
@inject IAuditService AuditService
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject IImageService ImageService
@using HairSalonStyleBook.Components
@using Microsoft.AspNetCore.Components.Forms
@implements IAsyncDisposable

<div class="cal-page">
    <!-- 헤더: 월 네비게이션 + 액션 버튼 -->
    <div class="cal-header">
        <button class="cal-nav-btn" @onclick="PrevMonth" title="이전 달">
            <i class="bi bi-chevron-left"></i>
        </button>
        <div class="cal-title-area">
            @if (!string.IsNullOrEmpty(_data.CustomTitle))
            {
                <div class="cal-custom-title">@_data.CustomTitle</div>
            }
            <h2 class="cal-month-title">@(_data.Year)년 @(_data.Month)월</h2>
        </div>
        <button class="cal-nav-btn" @onclick="NextMonth" title="다음 달">
            <i class="bi bi-chevron-right"></i>
        </button>
    </div>

    @if (_isAdmin)
    {
        <div class="cal-actions">
            <button class="btn btn-sm btn-outline-secondary" @onclick="Undo" disabled="@(_undoStack.Count == 0)" title="실행 취소 (Ctrl+Z)">
                <i class="bi bi-arrow-counterclockwise"></i>
            </button>
            <button class="btn btn-sm @(_data.IsPublished ? "btn-success" : "btn-outline-secondary")"
                    @onclick="TogglePublish" disabled="@_publishing">
                <i class="bi @(_data.IsPublished ? "bi-eye-fill" : "bi-eye-slash")"></i>
                @(_data.IsPublished ? "게시중" : "미게시")
            </button>
            <button class="btn btn-sm btn-outline-secondary" @onclick="ShowCopyMonth" title="월 복사">
                <i class="bi bi-copy"></i>
            </button>
            <button class="btn btn-sm btn-outline-secondary" @onclick="ExportPng" disabled="@_exporting" title="이미지 저장">
                @if (_exporting)
                {
                    <span class="spinner-border spinner-border-sm"></span>
                }
                else
                {
                    <i class="bi bi-download"></i>
                }
            </button>
            <div class="cal-more-menu">
                <button class="btn btn-sm btn-outline-secondary" @onclick="ToggleMoreMenu" title="더보기">
                    <i class="bi bi-three-dots-vertical"></i>
                </button>
                @if (_showMoreMenu)
                {
                    <div class="cal-dropdown" @onclick:stopPropagation="true">
                        <button class="cal-dropdown-item" @onclick="LockAllElements">
                            <i class="bi bi-lock"></i> 전체 잠금
                        </button>
                        <button class="cal-dropdown-item" @onclick="UnlockAllElements">
                            <i class="bi bi-unlock"></i> 전체 해제
                        </button>
                        <button class="cal-dropdown-item" @onclick="AlignSelectedCenter" disabled="@(_selectedElementId == null)">
                            <i class="bi bi-align-center"></i> 중앙 정렬
                        </button>
                        <hr style="margin:0.25rem 0;" />
                        <button class="cal-dropdown-item" @onclick="ClearAllElements" disabled="@(_data.FreeElements.Count == 0)">
                            <i class="bi bi-eraser"></i> 요소 전체 삭제
                        </button>
                        <button class="cal-dropdown-item text-danger" @onclick="ResetMonth">
                            <i class="bi bi-arrow-clockwise"></i> 월 초기화
                        </button>
                        <hr style="margin:0.25rem 0;" />
                        <button class="cal-dropdown-item text-danger" @onclick="DeleteMonthData">
                            <i class="bi bi-trash3"></i> 월 데이터 삭제
                        </button>
                    </div>
                }
            </div>
            <button class="btn btn-sm btn-primary" @onclick="Save" disabled="@_saving">
                @if (_saving)
                {
                    <span class="spinner-border spinner-border-sm me-1"></span>
                }
                <i class="bi bi-floppy"></i> 저장
            </button>
            @if (_saveMessage != null)
            {
                <span class="cal-save-msg">@_saveMessage</span>
            }
        </div>

        <!-- 월 복사 모달 -->
        @if (_showCopyModal)
        {
            <div class="cal-modal-overlay" @onclick="() => { _showCopyModal = false; StateHasChanged(); }">
                <div class="cal-modal" @onclick:stopPropagation="true">
                    <div class="cal-modal-header">
                        <span><i class="bi bi-copy"></i> 월 복사</span>
                        <button class="cal-cell-editor-close" @onclick="() => { _showCopyModal = false; StateHasChanged(); }">
                            <i class="bi bi-x-lg"></i>
                        </button>
                    </div>
                    <div class="cal-modal-body">
                        <p style="font-size:0.8rem;color:var(--salon-gray);">현재 @(_data.Year)년 @(_data.Month)월 꾸미기를 다른 달로 복사합니다.</p>
                        <div class="d-flex gap-2 align-items-center mb-2">
                            <select class="form-select form-select-sm" style="width:auto;" @bind="_copyTargetYear">
                                @for (var yr = DateTime.Now.Year - 1; yr <= DateTime.Now.Year + 2; yr++)
                                {
                                    <option value="@yr">@(yr)년</option>
                                }
                            </select>
                            <select class="form-select form-select-sm" style="width:auto;" @bind="_copyTargetMonth">
                                @for (var mo = 1; mo <= 12; mo++)
                                {
                                    <option value="@mo">@(mo)월</option>
                                }
                            </select>
                        </div>
                        <div class="d-flex gap-2">
                            <button class="btn btn-sm btn-primary" @onclick="CopyMonth" disabled="@_copyingMonth">
                                @if (_copyingMonth)
                                {
                                    <span class="spinner-border spinner-border-sm me-1"></span>
                                }
                                복사하기
                            </button>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => { _showCopyModal = false; StateHasChanged(); }">취소</button>
                        </div>
                        @if (_copyMessage != null)
                        {
                            <div class="mt-2" style="font-size:0.75rem;color:var(--salon-green);">@_copyMessage</div>
                        }
                    </div>
                </div>
            </div>
        }
    }

    @if (_loading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-secondary" role="status"></div>
            <div class="mt-2 text-muted" style="font-size:0.85rem;">캘린더 불러오는 중...</div>
        </div>
    }
    else if (!_isAdmin && !_data.IsPublished)
    {
        <!-- Viewer: 미게시 안내 + 게시된 월 목록 -->
        <div class="cal-empty">
            <i class="bi bi-calendar-x" style="font-size:2.5rem;opacity:0.3;"></i>
            <div>이 달의 캘린더가 아직 공개되지 않았어요</div>
            @if (_publishedMonths.Count > 0)
            {
                <div class="cal-published-list">
                    <span style="font-size:0.75rem;color:var(--salon-gray);">공개된 캘린더:</span>
                    @foreach (var pm in _publishedMonths)
                    {
                        var m = pm;
                        <button class="cal-published-btn" @onclick="() => LoadMonth(m.Year, m.Month)">
                            @(m.Year)년 @(m.Month)월
                        </button>
                    }
                </div>
            }
        </div>
    }
    else
    {
        <!-- 캘린더 캔버스 -->
        <div class="cal-canvas" @ref="_canvasRef"
             style="background-color:@_data.BackgroundColor; @GetPatternStyle()"
             @onpointermove="OnCanvasPointerMove"
             @onpointerup="OnCanvasPointerUp"
             @onpointerleave="OnCanvasPointerUp">
            <!-- 요일 헤더 -->
            <div class="cal-dow-row">
                <span class="cal-dow sun">일</span>
                <span class="cal-dow">월</span>
                <span class="cal-dow">화</span>
                <span class="cal-dow">수</span>
                <span class="cal-dow">목</span>
                <span class="cal-dow">금</span>
                <span class="cal-dow sat">토</span>
            </div>

            <!-- 날짜 그리드 -->
            <div class="cal-grid">
                @{
                    var firstDay = new DateTime(_data.Year, _data.Month, 1);
                    var daysInMonth = DateTime.DaysInMonth(_data.Year, _data.Month);
                    var startDow = (int)firstDay.DayOfWeek;
                }
                @for (var i = 0; i < startDow; i++)
                {
                    <div class="cal-cell empty"></div>
                }
                @for (var d = 1; d <= daysInMonth; d++)
                {
                    var day = d;
                    var dayStr = day.ToString();
                    var hasDeco = _data.CellDecos.TryGetValue(dayStr, out var cellDeco) && !cellDeco.IsEmpty;
                    var isToday = _data.Year == DateTime.Now.Year && _data.Month == DateTime.Now.Month && day == DateTime.Now.Day;
                    var dow = (int)new DateTime(_data.Year, _data.Month, day).DayOfWeek;
                    var hasDDay = _data.DDays.TryGetValue(dayStr, out var ddayLabel);
                    <div class="cal-cell @(isToday ? "today" : "") @(hasDeco ? "decorated" : "") @(dow == 0 ? "sun" : "") @(dow == 6 ? "sat" : "") @(hasDDay ? "dday" : "") @(_editingDay == day ? "editing" : "")"
                         style="@(hasDeco ? $"background-color:{cellDeco!.BackgroundColor};" : "")"
                         @onclick="() => OnCellClick(day)">
                        <span class="cal-day-num">@day</span>
                        @if (hasDDay)
                        {
                            <span class="cal-dday-badge" title="@ddayLabel">@GetDDayText(day)</span>
                        }
                        @if (hasDeco)
                        {
                            @if (cellDeco!.Stickers.Count > 0)
                            {
                                <div class="cal-cell-stickers">
                                    @foreach (var sticker in cellDeco.Stickers)
                                    {
                                        <span>@sticker</span>
                                    }
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(cellDeco.Memo))
                            {
                                <div class="cal-cell-memo" style="@(!string.IsNullOrEmpty(cellDeco.TextColor) ? $"color:{cellDeco.TextColor};" : "")">
                                    @cellDeco.Memo
                                </div>
                            }
                        }
                    </div>
                }
            </div>

            <!-- 자유 배치 요소 (캔버스 오버레이) -->
            @foreach (var elem in _data.FreeElements.OrderBy(e => e.ZIndex))
            {
                var el = elem;
                <div class="cal-free-elem @(_selectedElementId == el.Id ? "selected" : "") @(el.IsLocked ? "locked" : "")"
                     style="left:@FPct(el.X);top:@FPct(el.Y);transform:rotate(@FDeg(el.Rotation)) scale(@FScl(el.Scale));opacity:@FScl(el.Opacity);z-index:@(el.ZIndex + 10);"
                     @onpointerdown="e => OnElementPointerDown(e, el)"
                     @onpointerdown:preventDefault="@(_isAdmin && !el.IsLocked)">
                    @switch (el.Type)
                    {
                        case "emoji":
                            <span class="cal-elem-emoji">@el.Content</span>
                            break;
                        case "text":
                            <span class="cal-elem-text gd-font-@el.Font" style="color:@el.Color;">@el.Content</span>
                            break;
                        case "washi":
                            <div class="cal-elem-washi washi-@el.Pattern" style="width:@FPx(el.Width);"></div>
                            break;
                        case "svg":
                            <span class="cal-elem-svg" style="@(el.Color != "#333333" ? $"color:{el.Color};" : "")">@GetSvgSticker(el.Content)</span>
                            break;
                        case "image":
                            <div class="cal-elem-img-wrap cal-frame-@el.Frame">
                                <img class="cal-elem-img" src="@el.Content" alt="deco" />
                            </div>
                            break;
                    }
                    @if (el.IsLocked && _isAdmin)
                    {
                        <i class="bi bi-lock-fill cal-lock-badge"></i>
                    }
                </div>
            }
        </div>

        <!-- 셀 편집 팝오버 (Admin 전용) -->
        @if (_isAdmin && _editingDay.HasValue)
        {
            var editDayStr = _editingDay.Value.ToString();
            if (!_data.CellDecos.ContainsKey(editDayStr))
                _data.CellDecos[editDayStr] = new CalendarCellDeco();
            var editCell = _data.CellDecos[editDayStr];

            <div class="cal-cell-editor" @onclick:stopPropagation="true">
                <div class="cal-cell-editor-header">
                    <span><i class="bi bi-pencil-square"></i> @(_data.Month)월 @(_editingDay)일 꾸미기</span>
                    <button class="cal-cell-editor-close" @onclick="CloseCellEditor"><i class="bi bi-x-lg"></i></button>
                </div>

                <!-- 배경색 -->
                <div class="cal-cell-editor-section">
                    <label>배경색</label>
                    <div class="cal-color-grid">
                        <button class="cal-color-btn @(string.IsNullOrEmpty(editCell.BackgroundColor) ? "active" : "")"
                                style="background:transparent;border:1px dashed #ccc;"
                                title="없음"
                                @onclick="() => { editCell.BackgroundColor = string.Empty; StateHasChanged(); }">
                            <i class="bi bi-x" style="font-size:0.6rem;color:#ccc;"></i>
                        </button>
                        @foreach (var color in _cellColors)
                        {
                            var c = color;
                            <button class="cal-color-btn @(editCell.BackgroundColor == c ? "active" : "")"
                                    style="background:@c;"
                                    @onclick="() => { editCell.BackgroundColor = c; StateHasChanged(); }"></button>
                        }
                    </div>
                </div>

                <!-- 메모 -->
                <div class="cal-cell-editor-section">
                    <label>메모 <span class="cal-char-count">@(editCell.Memo.Length)/20</span></label>
                    <input type="text" class="form-control form-control-sm"
                           maxlength="20" placeholder="짧은 메모..."
                           value="@editCell.Memo"
                           @oninput="e => { editCell.Memo = e.Value?.ToString() ?? string.Empty; StateHasChanged(); }" />
                </div>

                <!-- 메모 텍스트 색상 -->
                @if (!string.IsNullOrEmpty(editCell.Memo))
                {
                    <div class="cal-cell-editor-section">
                        <label>텍스트 색상</label>
                        <div class="cal-color-grid">
                            @foreach (var color in _textColors)
                            {
                                var c = color;
                                <button class="cal-color-btn sm @(editCell.TextColor == c ? "active" : "")"
                                        style="background:@c;"
                                        @onclick="() => { editCell.TextColor = c; StateHasChanged(); }"></button>
                            }
                        </div>
                    </div>
                }

                <!-- 스티커 -->
                <div class="cal-cell-editor-section">
                    <label>스티커 <span class="cal-char-count">@(editCell.Stickers.Count)/3</span></label>
                    @if (editCell.Stickers.Count > 0)
                    {
                        <div class="cal-placed-stickers">
                            @for (var si = 0; si < editCell.Stickers.Count; si++)
                            {
                                var idx = si;
                                <span class="cal-placed-sticker" @onclick="() => RemoveCellSticker(editCell, idx)" title="클릭하여 제거">
                                    @editCell.Stickers[idx] <i class="bi bi-x-circle-fill"></i>
                                </span>
                            }
                        </div>
                    }
                    @if (editCell.Stickers.Count < 3)
                    {
                        <div class="cal-sticker-grid">
                            @foreach (var sticker in _cellStickers)
                            {
                                var s = sticker;
                                <button class="cal-sticker-btn" @onclick="() => AddCellSticker(editCell, s)">@s</button>
                            }
                        </div>
                    }
                </div>

                <!-- D-Day 기념일 -->
                <div class="cal-cell-editor-section">
                    <label>D-Day 기념일</label>
                    @if (_data.DDays.ContainsKey(editDayStr))
                    {
                        <div class="d-flex gap-2 align-items-center">
                            <input type="text" class="form-control form-control-sm flex-grow-1"
                                   maxlength="10" placeholder="기념일명..."
                                   value="@_data.DDays[editDayStr]"
                                   @oninput="e => { _data.DDays[editDayStr] = e.Value?.ToString() ?? string.Empty; StateHasChanged(); }" />
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => { _data.DDays.Remove(editDayStr); StateHasChanged(); }" title="삭제">
                                <i class="bi bi-x"></i>
                            </button>
                        </div>
                    }
                    else
                    {
                        <button class="btn btn-sm btn-outline-secondary" style="font-size:0.7rem;"
                                @onclick="() => { _data.DDays[editDayStr] = string.Empty; StateHasChanged(); }">
                            <i class="bi bi-calendar-heart"></i> D-Day 설정
                        </button>
                    }
                </div>

                <!-- 셀 복사/붙여넣기 -->
                <div class="cal-cell-editor-section">
                    <div class="d-flex gap-2">
                        <button class="btn btn-sm btn-outline-secondary" style="font-size:0.7rem;"
                                @onclick="() => CopyCellDeco(editDayStr)" disabled="@(editCell.IsEmpty)">
                            <i class="bi bi-clipboard"></i> 복사
                        </button>
                        @if (_copiedCellDeco != null)
                        {
                            <button class="btn btn-sm btn-outline-primary" style="font-size:0.7rem;"
                                    @onclick="() => PasteCellDeco(editDayStr)">
                                <i class="bi bi-clipboard-check"></i> 붙여넣기
                            </button>
                        }
                    </div>
                </div>
            </div>
        }

        <!-- 자유 배치 도구 툴바 (Admin 전용) -->
        @if (_isAdmin)
        {
            <div class="cal-toolbar">
                <div class="cal-toolbar-tabs">
                    <button class="cal-tab @(_toolTab == 0 ? "active" : "")" @onclick="() => SetToolTab(0)" title="이모지">😊</button>
                    <button class="cal-tab @(_toolTab == 1 ? "active" : "")" @onclick="() => SetToolTab(1)" title="텍스트">Aa</button>
                    <button class="cal-tab @(_toolTab == 4 ? "active" : "")" @onclick="() => SetToolTab(4)" title="SVG 스티커">✂️</button>
                    <button class="cal-tab @(_toolTab == 5 ? "active" : "")" @onclick="() => SetToolTab(5)" title="이미지">📷</button>
                    <button class="cal-tab @(_toolTab == 2 ? "active" : "")" @onclick="() => SetToolTab(2)" title="와시테이프">🎀</button>
                    <button class="cal-tab @(_toolTab == 3 ? "active" : "")" @onclick="() => SetToolTab(3)" title="배경">🎨</button>
                    <button class="cal-tab @(_toolTab == 6 ? "active" : "")" @onclick="() => SetToolTab(6)" title="자동 꾸미기">🎲</button>
                    <span class="cal-elem-count">@(_data.FreeElements.Count)/50</span>
                </div>

                @if (_toolTab == 0)
                {
                    <!-- 이모지 스티커 추가 -->
                    <div class="cal-tool-panel">
                        <div class="cal-sticker-grid">
                            @foreach (var sticker in _freeStickers)
                            {
                                var s = sticker;
                                <button class="cal-sticker-btn" @onclick="() => AddFreeEmoji(s)"
                                        disabled="@(_data.FreeElements.Count >= 50)">@s</button>
                            }
                        </div>
                    </div>
                }
                else if (_toolTab == 1)
                {
                    <!-- 텍스트 추가 -->
                    <div class="cal-tool-panel">
                        <div class="d-flex gap-2 align-items-end">
                            <div class="flex-grow-1">
                                <input type="text" class="form-control form-control-sm"
                                       placeholder="텍스트 입력..." maxlength="30"
                                       @bind="_newText" @bind:event="oninput" />
                            </div>
                            <button class="btn btn-sm btn-outline-primary" @onclick="AddFreeText"
                                    disabled="@(string.IsNullOrWhiteSpace(_newText) || _data.FreeElements.Count >= 50)">
                                <i class="bi bi-plus"></i> 추가
                            </button>
                        </div>
                        <div class="cal-font-row mt-2">
                            @foreach (var font in _fonts)
                            {
                                var f = font;
                                <button class="cal-font-btn gd-font-@f.key @(_newTextFont == f.key ? "active" : "")"
                                        @onclick="() => { _newTextFont = f.key; StateHasChanged(); }">@f.label</button>
                            }
                        </div>
                        <div class="cal-color-grid mt-2">
                            @foreach (var color in _textColors)
                            {
                                var c = color;
                                <button class="cal-color-btn sm @(_newTextColor == c ? "active" : "")"
                                        style="background:@c;"
                                        @onclick="() => { _newTextColor = c; StateHasChanged(); }"></button>
                            }
                        </div>
                    </div>
                }
                else if (_toolTab == 2)
                {
                    <!-- 와시테이프 추가 -->
                    <div class="cal-tool-panel">
                        <div class="cal-washi-grid">
                            @foreach (var pattern in _washiPatterns)
                            {
                                var p = pattern;
                                <button class="cal-washi-btn" @onclick="() => AddFreeWashi(p.key)"
                                        disabled="@(_data.FreeElements.Count >= 50)">
                                    <div class="cal-elem-washi washi-@p.key" style="width:80px;height:14px;"></div>
                                    <span>@p.label</span>
                                </button>
                            }
                        </div>
                    </div>
                }
                else if (_toolTab == 3)
                {
                    <!-- 캘린더 배경 설정 -->
                    <div class="cal-tool-panel">
                        <label style="font-size:0.7rem;font-weight:600;color:var(--salon-gray);">배경색</label>
                        <div class="cal-color-grid mb-2">
                            @foreach (var color in _bgColors)
                            {
                                var c = color;
                                <button class="cal-color-btn @(_data.BackgroundColor == c ? "active" : "")"
                                        style="background:@c;"
                                        @onclick="() => { _data.BackgroundColor = c; StateHasChanged(); }"></button>
                            }
                        </div>
                        <label style="font-size:0.7rem;font-weight:600;color:var(--salon-gray);">패턴</label>
                        <div class="cal-pattern-grid">
                            @foreach (var pat in _bgPatterns)
                            {
                                var p = pat;
                                <button class="cal-pattern-btn @(_data.BackgroundPattern == p.key ? "active" : "")"
                                        @onclick="() => { _data.BackgroundPattern = p.key; StateHasChanged(); }">
                                    @p.label
                                </button>
                            }
                        </div>
                        <label class="mt-2" style="font-size:0.7rem;font-weight:600;color:var(--salon-gray);">커스텀 제목</label>
                        <input type="text" class="form-control form-control-sm" maxlength="30"
                               placeholder="예: 2월의 따뜻한 컬러" @bind="_data.CustomTitle" @bind:event="oninput" />
                        <label class="mt-2" style="font-size:0.7rem;font-weight:600;color:var(--salon-gray);">테마 프리셋</label>
                        <div class="cal-theme-grid">
                            @foreach (var theme in _themePresets)
                            {
                                var t = theme;
                                <button class="cal-theme-btn" @onclick="() => ApplyTheme(t)" title="@t.name">
                                    <div class="cal-theme-preview" style="background:@t.bg;">
                                        <span style="color:@t.accent;font-size:0.6rem;">@t.icon</span>
                                    </div>
                                    <span>@t.name</span>
                                </button>
                            }
                        </div>
                    </div>
                }
                else if (_toolTab == 4)
                {
                    <!-- SVG 스티커 추가 -->
                    <div class="cal-tool-panel">
                        <div class="cal-svg-grid">
                            @foreach (var sticker in SvgStickerLibrary.Stickers)
                            {
                                var s = sticker;
                                <button class="cal-svg-btn" @onclick="() => AddFreeSvg(s.Key)"
                                        disabled="@(_data.FreeElements.Count >= 50)" title="@s.Label">
                                    @(SvgStickerLibrary.GetSvg(s.Key))
                                    <span>@s.Label</span>
                                </button>
                            }
                        </div>
                    </div>
                }
                else if (_toolTab == 5)
                {
                    <!-- 이미지 업로드 -->
                    <div class="cal-tool-panel">
                        <div class="cal-upload-area">
                            <InputFile OnChange="OnImageSelected" accept="image/*"
                                       disabled="@(_uploading || _data.FreeElements.Count >= 50)" />
                            @if (_uploading)
                            {
                                <div class="mt-2 text-center">
                                    <span class="spinner-border spinner-border-sm"></span>
                                    <span style="font-size:0.75rem;color:var(--salon-gray);">업로드 중...</span>
                                </div>
                            }
                            @if (_uploadError != null)
                            {
                                <div class="mt-1" style="font-size:0.7rem;color:#e8847c;">@_uploadError</div>
                            }
                        </div>
                        <div style="font-size:0.65rem;color:var(--salon-gray);margin-top:0.4rem;">
                            최대 5MB, jpg/png/gif/webp
                        </div>
                    </div>
                }
                else if (_toolTab == 6)
                {
                    <!-- 자동 꾸미기 -->
                    <div class="cal-tool-panel">
                        <div style="font-size:0.75rem;color:var(--salon-gray);margin-bottom:0.5rem;">
                            버튼 하나로 캘린더를 자동 꾸며보세요!
                        </div>
                        <div class="d-flex flex-wrap gap-2">
                            <button class="btn btn-sm btn-outline-primary" @onclick="() => AutoDecorate(AutoDecoStyle.Cute)">
                                🌸 귀여운
                            </button>
                            <button class="btn btn-sm btn-outline-primary" @onclick="() => AutoDecorate(AutoDecoStyle.Elegant)">
                                ✨ 우아한
                            </button>
                            <button class="btn btn-sm btn-outline-primary" @onclick="() => AutoDecorate(AutoDecoStyle.Salon)">
                                ✂️ 미용실
                            </button>
                            <button class="btn btn-sm btn-outline-primary" @onclick="() => AutoDecorate(AutoDecoStyle.Nature)">
                                🌿 자연
                            </button>
                            <button class="btn btn-sm btn-outline-primary" @onclick="() => AutoDecorate(AutoDecoStyle.Party)">
                                🎉 파티
                            </button>
                        </div>
                        <div style="font-size:0.6rem;color:var(--salon-gray);margin-top:0.5rem;">
                            기존 자유 요소 위에 추가됩니다. 실행 취소로 되돌릴 수 있어요.
                        </div>
                    </div>
                }
            </div>

            <!-- 선택된 자유 요소 속성 편집 패널 -->
            @if (_selectedElementId != null)
            {
                var selElem = _data.FreeElements.FirstOrDefault(e => e.Id == _selectedElementId);
                if (selElem != null)
                {
                    <div class="cal-elem-editor" @onclick:stopPropagation="true">
                        <div class="cal-elem-editor-header">
                            <span>
                                @(selElem.Type switch { "emoji" => "이모지", "text" => "텍스트", "washi" => "와시테이프", "svg" => "SVG", "image" => "이미지", _ => "요소" })
                                편집
                            </span>
                            <div class="d-flex gap-1">
                                <button class="cal-cell-editor-close" @onclick="() => { _selectedElementId = null; StateHasChanged(); }">
                                    <i class="bi bi-x-lg"></i>
                                </button>
                            </div>
                        </div>

                        <!-- 텍스트 전용: 내용 수정 -->
                        @if (selElem.Type == "text")
                        {
                            <div class="cal-cell-editor-section">
                                <label>텍스트</label>
                                <input type="text" class="form-control form-control-sm" maxlength="30"
                                       value="@selElem.Content"
                                       @oninput="e => { selElem.Content = e.Value?.ToString() ?? string.Empty; StateHasChanged(); }" />
                                <div class="cal-font-row mt-1">
                                    @foreach (var font in _fonts)
                                    {
                                        var f = font;
                                        <button class="cal-font-btn gd-font-@f.key @(selElem.Font == f.key ? "active" : "")"
                                                @onclick="() => { selElem.Font = f.key; StateHasChanged(); }">@f.label</button>
                                    }
                                </div>
                                <div class="cal-color-grid mt-1">
                                    @foreach (var color in _textColors)
                                    {
                                        var c = color;
                                        <button class="cal-color-btn sm @(selElem.Color == c ? "active" : "")"
                                                style="background:@c;"
                                                @onclick="() => { selElem.Color = c; StateHasChanged(); }"></button>
                                    }
                                </div>
                            </div>
                        }

                        <!-- SVG 전용: 색상 -->
                        @if (selElem.Type == "svg")
                        {
                            <div class="cal-cell-editor-section">
                                <label>SVG 색상</label>
                                <div class="cal-color-grid">
                                    @foreach (var color in _svgColors)
                                    {
                                        var c = color;
                                        <button class="cal-color-btn sm @(selElem.Color == c ? "active" : "")"
                                                style="background:@c;"
                                                @onclick="() => { selElem.Color = c; StateHasChanged(); }"></button>
                                    }
                                </div>
                            </div>
                        }

                        <!-- 공통 속성 -->
                        <div class="cal-cell-editor-section">
                            <label>크기 <span class="cal-char-count">@selElem.Scale.ToString("F1")x</span></label>
                            <input type="range" class="form-range" min="0.3" max="5" step="0.1"
                                   value="@FScl(selElem.Scale)"
                                   @oninput="e => { if (double.TryParse(e.Value?.ToString(), System.Globalization.NumberStyles.Float, System.Globalization.CultureInfo.InvariantCulture, out var v)) selElem.Scale = v; StateHasChanged(); }" />
                        </div>
                        <div class="cal-cell-editor-section">
                            <label>회전 <span class="cal-char-count">@selElem.Rotation.ToString("F0")°</span></label>
                            <input type="range" class="form-range" min="0" max="360" step="5"
                                   value="@FScl(selElem.Rotation)"
                                   @oninput="e => { if (double.TryParse(e.Value?.ToString(), System.Globalization.NumberStyles.Float, System.Globalization.CultureInfo.InvariantCulture, out var v)) selElem.Rotation = v; StateHasChanged(); }" />
                        </div>
                        <div class="cal-cell-editor-section">
                            <label>투명도 <span class="cal-char-count">@((selElem.Opacity * 100).ToString("F0"))%</span></label>
                            <input type="range" class="form-range" min="0.1" max="1" step="0.1"
                                   value="@FScl(selElem.Opacity)"
                                   @oninput="e => { if (double.TryParse(e.Value?.ToString(), System.Globalization.NumberStyles.Float, System.Globalization.CultureInfo.InvariantCulture, out var v)) selElem.Opacity = v; StateHasChanged(); }" />
                        </div>

                        @if (selElem.Type == "washi")
                        {
                            <div class="cal-cell-editor-section">
                                <label>길이 <span class="cal-char-count">@selElem.Width.ToString("F0")px</span></label>
                                <input type="range" class="form-range" min="40" max="300" step="10"
                                       value="@FScl(selElem.Width)"
                                       @oninput="e => { if (double.TryParse(e.Value?.ToString(), System.Globalization.NumberStyles.Float, System.Globalization.CultureInfo.InvariantCulture, out var v)) selElem.Width = v; StateHasChanged(); }" />
                            </div>
                        }

                        @if (selElem.Type == "image")
                        {
                            <div class="cal-cell-editor-section">
                                <label>프레임</label>
                                <div class="cal-frame-grid">
                                    @foreach (var frame in _imageFrames)
                                    {
                                        var fr = frame;
                                        <button class="cal-frame-btn @(selElem.Frame == fr.key ? "active" : "")"
                                                @onclick="() => { selElem.Frame = fr.key; StateHasChanged(); }">
                                            @fr.label
                                        </button>
                                    }
                                </div>
                            </div>
                        }

                        <div class="cal-elem-editor-actions">
                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => DuplicateElement(selElem)" title="복제"
                                    disabled="@(_data.FreeElements.Count >= 50)">
                                <i class="bi bi-copy"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => AlignElement(selElem)" title="중앙 정렬">
                                <i class="bi bi-align-center"></i>
                            </button>
                            <button class="btn btn-sm @(selElem.IsLocked ? "btn-warning" : "btn-outline-secondary")"
                                    @onclick="() => ToggleLock(selElem)" title="@(selElem.IsLocked ? "잠금 해제" : "잠금")">
                                <i class="bi @(selElem.IsLocked ? "bi-lock-fill" : "bi-unlock")"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => MoveElementLayer(selElem, 1)" title="앞으로">
                                <i class="bi bi-layer-forward"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => MoveElementLayer(selElem, -1)" title="뒤로">
                                <i class="bi bi-layer-backward"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteElement(selElem)">
                                <i class="bi bi-trash3"></i> 삭제
                            </button>
                        </div>
                    </div>
                }
            }
        }
    }
</div>

@* 월 데이터 삭제 확인 모달 *@
@if (_confirmDelete)
{
    <div class="cal-delete-overlay" @onclick="() => { _confirmDelete = false; }">
        <div class="cal-delete-dialog" @onclick:stopPropagation="true">
            <p><strong>@(_data.Year)년 @(_data.Month)월</strong> 데이터를 삭제하시겠습니까?</p>
            <p class="text-muted" style="font-size:0.8rem;">Firestore에서 완전히 삭제됩니다. 복구할 수 없습니다.</p>
            <div class="d-flex gap-2 justify-content-end">
                <button class="btn btn-sm btn-outline-secondary" @onclick="() => { _confirmDelete = false; }">취소</button>
                <button class="btn btn-sm btn-danger" @onclick="ConfirmDeleteMonthData">삭제</button>
            </div>
        </div>
    </div>
}

@code {
    private CalendarMonth _data = new();
