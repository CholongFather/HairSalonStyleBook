    private static readonly (string key, string label)[] _washiPatterns = {
        ("stripe", "줄무늬"), ("dot", "도트"), ("floral", "플로럴"),
        ("plaid", "체크"), ("pastel", "파스텔"), ("holographic", "홀로그램")
