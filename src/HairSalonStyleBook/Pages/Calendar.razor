    private static readonly (string key, string label)[] _imageFrames = {
        ("none", "없음"), ("polaroid", "폴라로이드"), ("rounded", "둥근"),
        ("circle", "원형"), ("stamp", "우표"), ("shadow", "그림자")
    };

    // 테마 프리셋
    private static readonly (string name, string bg, string pattern, string accent, string icon)[] _themePresets = {
        ("봄 벚꽃", "#fff0f5", "none", "#f8bbd0", "🌸"),
        ("여름 바다", "#e3f2fd", "dots", "#6b8eb5", "🌊"),
        ("가을 단풍", "#fff8e1", "none", "#d4a574", "🍂"),
        ("겨울 눈꽃", "#f5f5f5", "dots", "#b0bec5", "❄️"),
        ("파스텔 핑크", "#ffeef2", "hearts", "#e8847c", "💖"),
        ("민트 그린", "#e8f5e9", "grid", "#7ba383", "🌿"),
        ("라벤더", "#ede7f6", "none", "#a855f7", "💜"),
        ("레트로", "#fffff0", "stripes", "#d4a574", "🎞️"),
    };

    // BoundingRect (JS interop용)
    private record BoundingRect(double Left, double Top, double Width, double Height);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _isAdmin)
        {
            _keyboardRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("calKeyboard.init", _keyboardRef);
        }
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("calKeyboard.dispose");
        }
        catch { /* 페이지 전환 시 무시 */ }
        _keyboardRef?.Dispose();
    }

    protected override async Task OnInitializedAsync()
    {
        var role = await AuthService.GetRoleAsync();
        _isAdmin = role == "Admin";

        if (!_isAdmin)
        {
            // Viewer: 게시된 월 목록 로드 → 최신 게시 월로 이동
            _publishedMonths = await CalendarService.GetPublishedMonthsAsync();
            if (_publishedMonths.Count > 0)
            {
                var latest = _publishedMonths.First();
                await LoadMonth(latest.Year, latest.Month);
            }
            else
            {
                var now = DateTime.Now;
                await LoadMonth(now.Year, now.Month);
            }
        }
        else
        {
            var now = DateTime.Now;
            await LoadMonth(now.Year, now.Month);
        }
    }

    private async Task LoadMonth(int year, int month)
    {
        _loading = true;
        StateHasChanged();

        _data = await CalendarService.GetMonthAsync(year, month);

        // 저장된 배경이 없으면 계절별 기본 배경 적용
        if (string.IsNullOrEmpty(_data.BackgroundColor))
        {
            var (bg, pattern) = GetSeasonalDefault(month);
            _data.BackgroundColor = bg;
            _data.BackgroundPattern = pattern;
        }

        _selectedElementId = null;
        _editingDay = null;
        _undoStack.Clear();
        _loading = false;
    }

    private static (string bg, string pattern) GetSeasonalDefault(int month) => CalendarPatterns.GetSeasonalDefault(month);

    private async Task PrevMonth()
    {
        if (!_isAdmin && _publishedMonths.Count > 0)
        {
            // Viewer: 이전 게시된 월로 이동
            var current = _publishedMonths.FindIndex(m => m.Year == _data.Year && m.Month == _data.Month);
            if (current >= 0 && current < _publishedMonths.Count - 1)
                await LoadMonth(_publishedMonths[current + 1].Year, _publishedMonths[current + 1].Month);
        }
        else
        {
            var prev = new DateTime(_data.Year, _data.Month, 1).AddMonths(-1);
            await LoadMonth(prev.Year, prev.Month);
        }
    }

    private async Task NextMonth()
    {
        if (!_isAdmin && _publishedMonths.Count > 0)
        {
            // Viewer: 다음 게시된 월로 이동
            var current = _publishedMonths.FindIndex(m => m.Year == _data.Year && m.Month == _data.Month);
            if (current > 0)
                await LoadMonth(_publishedMonths[current - 1].Year, _publishedMonths[current - 1].Month);
        }
        else
        {
            var next = new DateTime(_data.Year, _data.Month, 1).AddMonths(1);
            await LoadMonth(next.Year, next.Month);
        }
    }

    private async Task Save()
    {
        if (_saving) return;
        _saving = true;
        _saveMessage = null;
        StateHasChanged();

        try
        {
            await CalendarService.SaveMonthAsync(_data);
            await AuditService.LogAsync("Update", _data.Id, "다꾸캘린더", $"{_data.Year}년 {_data.Month}월 캘린더 저장");
            _saveMessage = "저장 완료!";
        }
        catch (Exception ex)
        {
            _saveMessage = $"저장 실패: {ex.Message}";
            Console.WriteLine($"[Calendar] 저장 예외: {ex.Message}");
        }
        finally
        {
            _saving = false;
            StateHasChanged();
            // 3초 후 메시지 숨김
            _ = Task.Delay(3000).ContinueWith(_ =>
            {
                _saveMessage = null;
                InvokeAsync(StateHasChanged);
            });
        }
    }

    private async Task TogglePublish()
    {
        if (_publishing) return;
        _publishing = true;
        StateHasChanged();

        try
        {
            _data.IsPublished = !_data.IsPublished;
            await CalendarService.SaveMonthAsync(_data);
            await AuditService.LogAsync(
                _data.IsPublished ? "Publish" : "Unpublish",
                _data.Id, "다꾸캘린더",
                $"{_data.Year}년 {_data.Month}월 캘린더 {(_data.IsPublished ? "게시" : "미게시")}");
        }
        catch (Exception ex)
        {
            _data.IsPublished = !_data.IsPublished; // 롤백
            Console.WriteLine($"[Calendar] 게시 토글 예외: {ex.Message}");
        }
        finally
        {
            _publishing = false;
            StateHasChanged();
        }
    }

    private void OnCellClick(int day)
    {
        if (!_isAdmin) return;
        // 같은 셀 클릭 시 토글
        _editingDay = _editingDay == day ? null : day;
        _selectedElementId = null;
        StateHasChanged();
    }

    private void CloseCellEditor()
    {
        // 빈 데코는 딕셔너리에서 제거
        if (_editingDay.HasValue)
        {
            var dayStr = _editingDay.Value.ToString();
            if (_data.CellDecos.TryGetValue(dayStr, out var cell) && cell.IsEmpty)
                _data.CellDecos.Remove(dayStr);
        }
        _editingDay = null;
        StateHasChanged();
    }

    private void AddCellSticker(CalendarCellDeco cell, string sticker)
    {
        if (cell.Stickers.Count >= 3) return;
        cell.Stickers.Add(sticker);
        StateHasChanged();
    }

    private void RemoveCellSticker(CalendarCellDeco cell, int index)
    {
        if (index >= 0 && index < cell.Stickers.Count)
            cell.Stickers.RemoveAt(index);
        StateHasChanged();
    }

    private async Task OnElementPointerDown(PointerEventArgs e, CalendarFreeElement elem)
    {
        if (!_isAdmin) return;
        _selectedElementId = elem.Id;
        _editingDay = null;

        // 잠긴 요소는 선택만 가능 (드래그 불가)
        if (!elem.IsLocked)
        {
            PushUndo(); // 드래그 시작 시 undo 스냅샷
            _isDragging = true;
            _dragElement = elem;
        }
        StateHasChanged();
    }

    private async Task OnCanvasPointerMove(PointerEventArgs e)
    {
        if (!_isDragging || _dragElement == null) return;

        try
        {
            var rect = await JS.InvokeAsync<BoundingRect>("gdGetRect", _canvasRef);
            if (rect.Width < 1 || rect.Height < 1) return;

            var x = Math.Clamp((e.ClientX - rect.Left) / rect.Width * 100, 0, 100);
            var y = Math.Clamp((e.ClientY - rect.Top) / rect.Height * 100, 0, 100);
            _dragElement.X = x;
            _dragElement.Y = y;
            StateHasChanged();
        }
        catch { /* JS interop 실패 시 무시 */ }
    }

    private void OnCanvasPointerUp(PointerEventArgs e)
    {
        _isDragging = false;
        _dragElement = null;
    }

    // -- 도구 탭 --
    private void SetToolTab(int tab)
    {
        _toolTab = _toolTab == tab ? -1 : tab;
        _editingDay = null;
        StateHasChanged();
    }

