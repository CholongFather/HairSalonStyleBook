        "❤️", "💖", "💕", "✨", "⭐", "🌸", "🌹", "🌻",
        "🌼", "🌷", "🫶", "🍂", "💎", "👑", "🎀", "🎁",
        "📷", "🎨", "🎵", "☕", "🌈", "🪡", "🐶", "🐱",
        "💇‍♀️", "✂️", "💈", "🪮", "🎂", "🔥", "💰", "🌙"
    };

    // 글씨체 목록
    private static readonly (string key, string label)[] _fonts = {
        ("default", "기본"), ("handwrite", "손글씨"), ("cute", "귀여운"), ("brush", "붓"),
        ("elegant", "우아"), ("round", "둥근"), ("bold", "굵은"), ("title", "제목")
    };

