    }

    // -- 실행 취소 --
    private void PushUndo()
    {
        var snapshot = SerializeData();
        _undoStack.Push(snapshot);
        // 스택 크기 제한
        if (_undoStack.Count > MaxUndoSteps)
        {
            var temp = _undoStack.ToArray();
            _undoStack.Clear();
            for (var i = 0; i < MaxUndoSteps; i++)
                _undoStack.Push(temp[MaxUndoSteps - 1 - i]);
        }
    }

    private void Undo()
    {
        if (_undoStack.Count == 0) return;
        var snapshot = _undoStack.Pop();
        DeserializeData(snapshot);
        _selectedElementId = null;
        _editingDay = null;
        StateHasChanged();
    }

    private string SerializeData()
    {
        return System.Text.Json.JsonSerializer.Serialize(_data, new System.Text.Json.JsonSerializerOptions
        {
            PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase
        });
    }

    private void DeserializeData(string json)
    {
        var restored = System.Text.Json.JsonSerializer.Deserialize<CalendarMonth>(json, new System.Text.Json.JsonSerializerOptions
        {
            PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase
        });
        if (restored != null) _data = restored;
    }

    // -- 테마 프리셋 적용 --
    private void ApplyTheme((string name, string bg, string pattern, string accent, string icon) theme)
    {
        PushUndo();
        _data.BackgroundColor = theme.bg;
        _data.BackgroundPattern = theme.pattern;
        StateHasChanged();
    }

    // -- 월 복사 --
    private void ShowCopyMonth()
    {
        var next = new DateTime(_data.Year, _data.Month, 1).AddMonths(1);
        _copyTargetYear = next.Year;
        _copyTargetMonth = next.Month;
        _copyMessage = null;
        _showCopyModal = true;
        StateHasChanged();
    }

    private async Task CopyMonth()
    {
        if (_copyingMonth) return;
        if (_copyTargetYear == _data.Year && _copyTargetMonth == _data.Month)
        {
            _copyMessage = "같은 달로는 복사할 수 없습니다.";
            StateHasChanged();
            return;
        }

        _copyingMonth = true;
        _copyMessage = null;
        StateHasChanged();

        try
        {
            var copy = new CalendarMonth
            {
                Year = _copyTargetYear,
                Month = _copyTargetMonth,
                BackgroundColor = _data.BackgroundColor,
                BackgroundPattern = _data.BackgroundPattern,
                CustomTitle = _data.CustomTitle,
                DDays = new Dictionary<string, string>(_data.DDays),
                CellDecos = _data.CellDecos.ToDictionary(
                    kv => kv.Key,
                    kv => new CalendarCellDeco
                    {
                        BackgroundColor = kv.Value.BackgroundColor,
                        Memo = kv.Value.Memo,
                        TextColor = kv.Value.TextColor,
                        Stickers = new List<string>(kv.Value.Stickers),
                    }),
                FreeElements = _data.FreeElements.Select(e => new CalendarFreeElement
                {
                    Type = e.Type,
                    Content = e.Content,
                    X = e.X,
                    Y = e.Y,
                    Scale = e.Scale,
                    Rotation = e.Rotation,
                    ZIndex = e.ZIndex,
                    Opacity = e.Opacity,
                    Font = e.Font,
                    Color = e.Color,
                    Width = e.Width,
                    Pattern = e.Pattern,
                    IsLocked = e.IsLocked,
                    Frame = e.Frame,
                }).ToList(),
                IsPublished = false,
            };

            await CalendarService.SaveMonthAsync(copy);
            await AuditService.LogAsync("Create", copy.Id, "다꾸캘린더",
                $"{_data.Year}년 {_data.Month}월 → {_copyTargetYear}년 {_copyTargetMonth}월 복사");
            _copyMessage = $"{_copyTargetYear}년 {_copyTargetMonth}월로 복사 완료!";
        }
        catch (Exception ex)
        {
            _copyMessage = $"복사 실패: {ex.Message}";
            Console.WriteLine($"[Calendar] 월 복사 예외: {ex.Message}");
        }
        finally
        {
            _copyingMonth = false;
            StateHasChanged();
        }
    }

    // -- 이미지 내보내기 --
    private async Task ExportPng()
    {
        if (_exporting) return;
        _exporting = true;
        _selectedElementId = null;
        StateHasChanged();
