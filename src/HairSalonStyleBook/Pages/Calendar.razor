    private async Task OnImageSelected(InputFileChangeEventArgs e)
    {
        if (_uploading || _data.FreeElements.Count >= 50) return;

        var file = e.File;
        _uploadError = null;

        // 5MB 제한 (프로젝트 규칙: silent skip 금지)
        if (file.Size > 5 * 1024 * 1024)
        {
            _uploadError = "파일 크기가 5MB를 초과합니다. 더 작은 파일을 선택해주세요.";
            StateHasChanged();
            return;
        }

        _uploading = true;
        StateHasChanged();

        try
        {
            using var stream = file.OpenReadStream(5 * 1024 * 1024);
            using var ms = new System.IO.MemoryStream();
            await stream.CopyToAsync(ms);
            var data = ms.ToArray();

            var fileName = $"cal_{DateTime.UtcNow:yyyyMMddHHmmss}_{Guid.NewGuid():N[..6]}{System.IO.Path.GetExtension(file.Name)}";
            var url = await ImageService.UploadAsync(fileName, data, file.ContentType, "calendar");

            PushUndo();
            var elem = new CalendarFreeElement
            {
                Type = "image",
                Content = url,
                X = 50,
                Y = 50,
                Scale = 1.0,
                ZIndex = _data.FreeElements.Count + 1
            };
            _data.FreeElements.Add(elem);
            _selectedElementId = elem.Id;
        }
        catch (Exception ex)
        {
            _uploadError = $"업로드 실패: {ex.Message}";
            Console.WriteLine($"[Calendar] 이미지 업로드 예외: {ex.Message}");
        }
        finally
        {
            _uploading = false;
            StateHasChanged();
        }
    }

