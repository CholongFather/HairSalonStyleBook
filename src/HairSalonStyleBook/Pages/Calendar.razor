    // -- 키보드 단축키 --
    [JSInvokable]
    [JSInvokable]
    public void OnKeyDelete()
    {
        if (_selectedElementId == null) return;
        var elem = _data.FreeElements.FirstOrDefault(e => e.Id == _selectedElementId);
        if (elem != null && !elem.IsLocked)
        {
            PushUndo();
            _data.FreeElements.Remove(elem);
            _selectedElementId = null;
            StateHasChanged();
        }
    }

    [JSInvokable]
    public void OnKeyEscape()
    {
