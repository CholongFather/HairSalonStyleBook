    private bool _exporting;

    // 더보기 메뉴
    private bool _showMoreMenu;

    // 셀 데코 복사
    private CalendarCellDeco? _copiedCellDeco;

    // 키보드 단축키
    private DotNetObjectReference<Calendar>? _keyboardRef;

    // SVG 색상 팔레트
    private static readonly string[] _svgColors = {
        "#333333", "#666666", "#e8847c", "#d4a574",
