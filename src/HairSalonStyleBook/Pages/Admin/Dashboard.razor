        gap: 12px;
    }

    .opt-scan-result {
        font-size: 0.82rem;
        color: var(--salon-green);
    }

    .opt-progress {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .opt-progress-text {
        font-size: 0.82rem;
        font-weight: 600;
        color: var(--text-primary, #333);
    }

    .opt-current-file {
        font-size: 0.72rem;
        color: var(--text-secondary, #888);
        font-family: monospace;
    }

    /* 체크리스트 */
    .checklist-date {
        font-family: var(--font-serif);
        font-size: 0.8rem;
        color: var(--salon-gray);
        display: flex;
        align-items: center;
        gap: 0.3rem;
    }

    .checklist-container {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .checklist-group {
        background: var(--salon-white);
        border: 1px solid var(--salon-light-gray);
        border-radius: 12px;
        overflow: hidden;
    }

    .checklist-group-header {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.7rem 1rem;
        background: var(--salon-bg);
        font-family: var(--font-serif);
        font-size: 0.85rem;
        font-weight: 700;
        color: var(--salon-dark);
        border-bottom: 1px solid var(--salon-light-gray);
    }

    .checklist-group-header i {
        font-size: 0.9rem;
    }

    .checklist-item {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        padding: 0.65rem 1rem;
        cursor: pointer;
        transition: all 0.2s;
        border-bottom: 1px solid rgba(232, 227, 220, 0.3);
    }

    .checklist-item:last-child {
        border-bottom: none;
    }

    .checklist-item:hover {
        background: rgba(123, 163, 131, 0.04);
    }

    .checklist-item:active {
        transform: scale(0.99);
    }

    .checklist-checkbox i {
        font-size: 1.1rem;
        color: var(--salon-light-gray);
        transition: color 0.2s;
    }

    .checklist-item.checked .checklist-checkbox i {
        color: var(--salon-green);
    }

    .checklist-text {
        font-family: var(--font-serif);
        font-size: 0.84rem;
        color: var(--salon-dark);
        transition: all 0.2s;
    }

    .checklist-item.checked .checklist-text {
        color: var(--salon-gray);
        text-decoration: line-through;
    }

    /* 진행률 바 */
    .checklist-progress {
        margin-top: 1.2rem;
        display: flex;
        align-items: center;
        gap: 0.8rem;
    }

    .progress-bar-wrap {
        flex: 1;
        height: 6px;
        background: var(--salon-light-gray);
        border-radius: 3px;
        overflow: hidden;
    }

    .progress-bar-fill {
        height: 100%;
        background: var(--salon-green);
        border-radius: 3px;
        transition: width 0.3s ease;
    }

    .progress-text {
        font-family: var(--font-serif);
        font-size: 0.72rem;
        color: var(--salon-gray);
        white-space: nowrap;
    }

    /* 이미지 개수 뱃지 */
    .badge-img-count {
        display: inline-block;
        font-size: 0.65rem;
        padding: 0.1rem 0.35rem;
        background: var(--salon-light-gray);
        color: var(--salon-gray);
        border-radius: 4px;
        margin-left: 0.3rem;
        vertical-align: middle;
    }

    /* 정렬 헤더 */
    .sortable-th {
        cursor: pointer;
        user-select: none;
        white-space: nowrap;
    }

    .sortable-th:hover {
        color: var(--salon-green);
    }

    .sort-icon {
        font-size: 0.65rem;
        margin-left: 2px;
        vertical-align: middle;
    }

    /* 게시 필터 */
    .publish-filter-btn {
        font-size: 0.75rem;
        white-space: nowrap;
        border-radius: 6px;
    }

    /* 보안 서브 탭 */
    .security-sub-tabs {
        display: flex;
        gap: 0.25rem;
        margin-bottom: 1.2rem;
        border-bottom: 2px solid var(--salon-light-gray);
    }

    .security-sub-tab {
        font-family: var(--font-serif);
        font-size: 0.82rem;
        font-weight: 600;
        padding: 0.5rem 0.8rem;
        border: none;
        background: none;
        color: var(--salon-gray);
        cursor: pointer;
        border-bottom: 2px solid transparent;
        margin-bottom: -2px;
        transition: all 0.2s;
    }

    .security-sub-tab.active {
        color: var(--salon-black);
        border-bottom-color: var(--salon-black);
    }

    .security-sub-tab:hover {
        color: var(--salon-dark);
    }

    /* 감사 로그 배지 */
    .audit-badge {
        font-size: 0.72rem;
        padding: 2px 8px;
        font-weight: 700;
        border-radius: 4px;
    }

    .audit-create { background: #d4edda; color: #155724; }
    .audit-update { background: #fff3cd; color: #856404; }
    .audit-delete { background: #f8d7da; color: #842029; }

    /* 보안 탭 */
    .security-blocked-section {
        background: #fff3f3;
        border: 1px solid #ffcccc;
        border-radius: 10px;
        padding: 1rem 1.2rem;
        margin-bottom: 1.2rem;
    }

    .security-blocked-section h6 {
        font-family: var(--font-serif);
        font-size: 0.85rem;
        font-weight: 700;
        color: #a94442;
        margin-bottom: 0.7rem;
    }

    .security-blocked-list {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
    }

    .security-blocked-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.5rem;
        background: white;
        border: 1px solid #f0d0d0;
        border-radius: 6px;
        padding: 0.4rem 0.7rem;
    }

    .security-blocked-item code {
        font-size: 0.75rem;
        color: #a94442;
    }

    .security-attempts-section h6 {
        font-family: var(--font-serif);
        font-size: 0.85rem;
        font-weight: 700;
        margin-bottom: 0.7rem;
    }

    .security-table .device-info {
        display: block;
        font-size: 0.8rem;
        font-weight: 600;
    }

    .security-table .device-fp {
        font-size: 0.68rem;
        color: var(--salon-gray);
    }

    .security-table .attempt-fail {
        background: #fff8f8;
    }

    .security-table .attempt-blocked {
        opacity: 0.6;
    }

    /* FAQ 관리 */
    .faq-admin-list {
        display: flex;
        flex-direction: column;
        gap: 0.8rem;
    }

    .faq-admin-item {
        background: white;
        border: 1px solid #eee;
        border-radius: 10px;
        padding: 0.8rem;
        transition: box-shadow 0.2s;
    }

    .faq-admin-item:hover {
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    }

    .faq-admin-header {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 0.4rem;
    }

    .faq-admin-order {
        width: 24px;
        height: 24px;
        background: var(--salon-primary, #c9a96e);
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.75rem;
        font-weight: 700;
        flex-shrink: 0;
    }

    .faq-admin-title {
        flex: 1;
        font-size: 0.9rem;
    }

    .faq-admin-actions {
        display: flex;
        gap: 0.3rem;
    }

    .faq-admin-actions .btn {
        padding: 0.15rem 0.4rem;
        font-size: 0.75rem;
    }

    .faq-admin-image {
        margin: 0.5rem 0;
        border-radius: 8px;
        overflow: hidden;
        border: 1px solid #eee;
    }

    .faq-admin-image img {
        width: 100%;
        max-height: 200px;
        object-fit: cover;
    }

    .faq-admin-desc {
        font-size: 0.82rem;
        color: #666;
        white-space: pre-wrap;
        line-height: 1.5;
    }

    .faq-edit-image-preview {
        position: relative;
        border-radius: 8px;
        overflow: hidden;
        border: 1px solid #eee;
    }

    .faq-edit-image-preview img {
        width: 100%;
        max-height: 250px;
        object-fit: contain;
        background: #f8f8f8;
    }

    .faq-edit-image-preview .btn {
        position: absolute;
        top: 0.5rem;
        right: 0.5rem;
    }

    @@media (max-width: 576px) {
        .admin-header {
            flex-direction: column;
            align-items: flex-start;
        }

        .admin-tab {
            font-size: 0.73rem;
            padding: 0.45rem 0.5rem;
        }

        .shop-section {
            padding: 1rem;
        }

        .checklist-item {
            padding: 0.55rem 0.8rem;
        }

        .security-table th:nth-child(3),
        .security-table td:nth-child(3) {
            display: none;
        }
    }

    /* -- 매장 관리 서브탭 -- */
    .shop-sub-tab-bar {
        display: flex;
        gap: 0.5rem;
        padding: 0.5rem 0;
        margin-bottom: 1rem;
        border-bottom: 1px solid var(--salon-light-gray);
        overflow-x: auto;
    }

    .shop-sub-tab {
        padding: 0.45rem 1.2rem;
        border: 1px solid var(--salon-light-gray);
        background: var(--salon-white);
        border-radius: 20px;
        font-size: 0.82rem;
        color: var(--salon-gray);
        cursor: pointer;
        transition: all 0.2s;
        white-space: nowrap;
    }

    .shop-sub-tab:hover {
        border-color: var(--salon-green, #7ba383);
        color: var(--salon-dark);
    }

    .shop-sub-tab.active {
        background: var(--salon-green, #7ba383);
        border-color: var(--salon-green, #7ba383);
        color: #fff;
    }

    /* -- FAQ 아코디언 -- */
    .faq-acc-group-header {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        font-size: 0.82rem;
        font-weight: 700;
        color: #555;
        padding: 0.6rem 0.2rem 0.3rem;
        border-bottom: 1px solid #eee;
        margin-top: 0.5rem;
    }

    .faq-acc-group-header i {
        color: var(--salon-green, #7ba383);
    }

    .faq-acc-group-count {
        font-size: 0.7rem;
        font-weight: 400;
        color: #999;
        margin-left: 0.2rem;
    }

    .faq-acc-item {
        border: 1px solid #eee;
        border-radius: 12px;
        margin-top: 0.8rem;
        overflow: hidden;
        transition: box-shadow 0.2s;
    }

    .faq-acc-item.expanded {
        border-color: var(--salon-green, #7ba383);
        box-shadow: 0 4px 16px rgba(123, 163, 131, 0.15);
    }

    .faq-acc-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1.2rem 1.4rem;
        cursor: pointer;
        background: #fafafa;
        transition: background 0.15s;
        min-height: 60px;
    }

    .faq-acc-header:hover {
        background: #f0f0f0;
    }

    .faq-acc-item.expanded .faq-acc-header {
        background: rgba(123, 163, 131, 0.06);
        border-bottom: 1px solid #eee;
    }

    .faq-acc-title {
        font-size: 0.92rem;
        font-weight: 600;
        color: #333;
        flex: 1;
    }

    .faq-acc-chevron {
        font-size: 0.85rem;
        color: #aaa;
        flex-shrink: 0;
        transition: transform 0.2s;
    }

    .faq-acc-body {
        padding: 1.4rem 1.6rem;
        animation: faqAccFadeIn 0.2s ease;
    }

    @@keyframes faqAccFadeIn {
        from { opacity: 0; transform: translateY(-4px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .faq-acc-images {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        margin-bottom: 1rem;
    }

    .faq-acc-image {
        border-radius: 8px;
        overflow: hidden;
        border: 1px solid #eee;
    }

    .faq-acc-image img {
        width: 100%;
        max-height: 500px;
        object-fit: contain;
        background: #f8f8f8;
    }

    .faq-acc-desc {
        font-size: 0.88rem;
        color: #555;
        line-height: 1.8;
        max-height: 600px;
        overflow-y: auto;
    }

    .faq-acc-desc h3 {
        font-size: 1rem;
        font-weight: 700;
        margin: 0.5rem 0;
    }

    .faq-acc-desc ul, .faq-acc-desc ol {
        padding-left: 1.5rem;
        margin: 0.5rem 0;
    }

    .faq-acc-desc hr {
        border: none;
        border-top: 1px solid #e0e0e0;
        margin: 0.75rem 0;
    }

    .faq-acc-actions {
        display: flex;
        gap: 0.5rem;
        margin-top: 1rem;
        padding-top: 0.8rem;
        border-top: 1px solid #f0f0f0;
    }

    .faq-edit-form {
        padding: 0.5rem 0;
    }

    .faq-edit-image-preview {
        position: relative;
        display: inline-block;
    }

    .faq-edit-image-preview img {
        max-width: 200px;
        max-height: 150px;
        border-radius: 6px;
        border: 1px solid #eee;
    }

    /* ─── FAQ 카테고리 탭 ─── */
    .faq-category-tabs {
        display: flex;
        gap: 0;
        overflow-x: auto;
        margin-bottom: 0.8rem;
        border-bottom: 1px solid #e5e7eb;
        -webkit-overflow-scrolling: touch;
    }

    .faq-cat-tab {
        background: none;
        border: none;
        border-bottom: 2px solid transparent;
        padding: 0.5rem 0.8rem;
        font-size: 0.75rem;
        color: #888;
        white-space: nowrap;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 0.3rem;
        transition: all 0.2s;
    }

    .faq-cat-tab.active {
        color: var(--salon-primary, #7ba383);
        border-bottom-color: var(--salon-primary, #7ba383);
        font-weight: 600;
    }

    .faq-cat-tab:hover {
        color: #555;
    }

    .faq-cat-dot {
        display: inline-block;
        width: 8px;
        height: 8px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .faq-cat-count {
        font-size: 0.65rem;
        background: #f0f0f0;
        padding: 0 0.35rem;
        border-radius: 10px;
        color: #999;
    }

    .faq-cat-tab.active .faq-cat-count {
        background: rgba(123, 163, 131, 0.15);
        color: var(--salon-primary, #7ba383);
    }

    /* ─── 갤러리 스타일 ─── */
    .gallery-upload-area {
        border: 2px dashed #d0d5dd;
        border-radius: 12px;
        text-align: center;
        padding: 1.5rem;
        margin-bottom: 0.8rem;
        background: #fafbfc;
        transition: border-color 0.2s;
    }

    .gallery-upload-area:hover {
        border-color: var(--salon-primary, #7ba383);
    }

    .gallery-upload-input {
        display: none;
    }

    .gallery-upload-label {
        cursor: pointer;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.3rem;
        color: #888;
        font-size: 0.85rem;
    }

    .gallery-upload-label i {
        font-size: 2rem;
        color: var(--salon-primary, #7ba383);
    }

    .gallery-upload-label small {
        font-size: 0.7rem;
        color: #aaa;
    }

    .gallery-filter-bar {
        display: flex;
        gap: 0.3rem;
    }
    .gallery-filter-chip {
        padding: 2px 8px;
        border: 1px solid #ddd;
        border-radius: 12px;
        background: white;
        cursor: pointer;
        font-size: 0.7rem;
        color: #666;
        display: flex;
        align-items: center;
        gap: 3px;
    }
    .gallery-filter-chip.active {
        border-color: var(--salon-primary, #7ba383);
        background: rgba(123,163,131,0.1);
        color: var(--salon-primary, #7ba383);
        font-weight: 600;
    }

    .gallery-toolbar {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 0;
        margin-bottom: 0.5rem;
        flex-wrap: wrap;
    }

    .gallery-admin-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 8px;
    }

    .gallery-admin-card {
        position: relative;
        border-radius: 8px;
        overflow: hidden;
        border: 2px solid transparent;
        cursor: pointer;
        transition: border-color 0.2s;
        background: #f5f5f5;
        aspect-ratio: 3 / 4;
    }

    .gallery-admin-card.selected {
        border-color: var(--salon-primary, #7ba383);
    }

    .gallery-admin-card img {
        width: 100%;
        height: 100%;
        display: block;
        object-fit: cover;
        object-position: center;
    }

    /* 자유 배치 텍스트/스티커 (Admin 카드 내) */
    .gallery-admin-card .gd-free-text {
        position: absolute;
        text-shadow: 0 1px 3px rgba(0,0,0,0.6);
        white-space: nowrap;
        pointer-events: none;
        z-index: 2;
    }
    .gallery-admin-card .gd-free-sticker {
        position: absolute;
        line-height: 1;
        pointer-events: none;
        z-index: 2;
    }

    /* 앵글 선택 */
    .angle-select-row {
        display: flex;
        align-items: center;
        gap: 0.3rem;
        flex-wrap: wrap;
    }
    .angle-select-label {
        font-size: 0.75rem;
        font-weight: 600;
        color: #666;
    }
    .angle-select-chip {
        padding: 3px 10px;
        border: 1px solid #ddd;
        border-radius: 12px;
        background: white;
        cursor: pointer;
        font-size: 0.7rem;
        color: #666;
    }
    .angle-select-chip.active {
        border-color: var(--salon-primary, #7ba383);
        background: rgba(123,163,131,0.1);
        color: var(--salon-primary, #7ba383);
        font-weight: 600;
    }

    .gallery-check {
        position: absolute;
        top: 6px;
        left: 6px;
        font-size: 1.1rem;
        color: rgba(255,255,255,0.9);
        text-shadow: 0 1px 3px rgba(0,0,0,0.5);
    }

    .gallery-admin-card.selected .gallery-check {
        color: var(--salon-primary, #7ba383);
    }

    .gallery-admin-memo {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        background: linear-gradient(transparent, rgba(0,0,0,0.6));
        color: #fff;
        font-size: 0.65rem;
        padding: 1rem 0.4rem 0.3rem;
        overflow: hidden;
        white-space: nowrap;
        text-overflow: ellipsis;
    }

    .gallery-edit-btn {
        position: absolute;
        top: 6px;
        right: 6px;
        background: rgba(0,0,0,0.5);
        border: none;
        color: #fff;
        border-radius: 50%;
        width: 28px;
        height: 28px;
        font-size: 0.75rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: opacity 0.2s;
    }

    .gallery-admin-card:hover .gallery-edit-btn,
    .gallery-admin-card:hover .gallery-publish-btn {
        opacity: 1;
    }

    .gallery-publish-btn {
        position: absolute;
        bottom: 6px;
        right: 6px;
        background: rgba(0,0,0,0.5);
        border: none;
        color: #fff;
        border-radius: 50%;
        width: 28px;
        height: 28px;
        font-size: 0.75rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: opacity 0.2s;
    }

    .gallery-publish-btn.hidden-item {
        opacity: 1;
        background: rgba(220, 53, 69, 0.7);
    }

    .gallery-hidden-badge {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        background: rgba(0,0,0,0.6);
        color: #fff;
        font-size: 0.7rem;
        padding: 0.2rem 0.6rem;
        border-radius: 12px;
        pointer-events: none;
    }

    /* 잠금 버튼 */
    .gallery-admin-card:hover .gallery-lock-btn {
        opacity: 1;
    }
    .gallery-lock-btn {
        position: absolute;
        bottom: 6px;
        right: 38px;
        background: rgba(0,0,0,0.5);
        border: none;
        color: #fff;
        border-radius: 50%;
        width: 28px;
        height: 28px;
        font-size: 0.75rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: opacity 0.2s;
    }
    .gallery-lock-btn.locked {
        opacity: 1;
        background: rgba(255, 152, 0, 0.8);
    }
    .gallery-locked-badge {
        position: absolute;
        bottom: 4px;
        left: 4px;
        background: rgba(255, 152, 0, 0.8);
        color: #fff;
        font-size: 0.55rem;
        padding: 1px 5px;
        border-radius: 8px;
        pointer-events: none;
    }

    /* 스타일 검색 모달 */
    .modal-overlay {
        position: fixed;
        top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(0,0,0,0.5);
        z-index: 1050;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .style-search-modal {
        background: #fff;
        border-radius: 16px;
        width: 90%;
        max-width: 420px;
        max-height: 80vh;
        overflow: hidden;
        display: flex;
        flex-direction: column;
    }

    .style-search-modal-header {
        display: flex;
        justify-content: space-between;
