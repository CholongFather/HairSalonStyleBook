@page "/admin"
@attribute [Authorize(Roles = "Admin")]
@implements IDisposable
@inject IStyleService StyleService
@inject IAuditService AuditService
@inject IAuthService AuthService
@inject IShopConfigService ShopConfigService
@inject ILoginSecurityService LoginSecurityService
@inject IFaqService FaqService
@inject IGalleryService GalleryService
@inject IBeforeAfterService BAService
@inject IImageService ImageService
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS

<PageTitle>관리자 - 늘~오던 헤어살롱</PageTitle>

<div class="container admin-page">
    <!-- 통계 요약 카드 -->
    <div class="admin-stats-grid">
        <div class="admin-stat-card">
            <i class="bi bi-scissors stat-icon"></i>
            <div class="stat-numbers">
                <span class="stat-main">@_statStylePublished / @_statStyleTotal</span>
                <span class="stat-label">스타일</span>
            </div>
        </div>
        <div class="admin-stat-card">
            <i class="bi bi-images stat-icon"></i>
            <div class="stat-numbers">
                <span class="stat-main">@_statGalleryPublished / @_statGalleryTotal</span>
                <span class="stat-label">갤러리</span>
            </div>
        </div>
        <div class="admin-stat-card">
            <i class="bi bi-arrow-left-right stat-icon"></i>
            <div class="stat-numbers">
                <span class="stat-main">@_statBAPublished / @_statBATotal</span>
                <span class="stat-label">B/A</span>
            </div>
        </div>
        <div class="admin-stat-card">
            <i class="bi bi-question-circle stat-icon"></i>
            <div class="stat-numbers">
                <span class="stat-main">@_statFaqPublished / @_statFaqTotal</span>
                <span class="stat-label">FAQ</span>
            </div>
        </div>
    </div>

    <!-- 관리자 탭 -->
    <div class="admin-tab-bar">
        <button class="admin-tab @(_adminTab == 0 ? "active" : "")" @onclick="() => { StopSecurityAutoRefresh(); _adminTab = 0; }">
            <i class="bi bi-scissors"></i> 스타일
        </button>
        <button class="admin-tab @(_adminTab == 4 ? "active" : "")" @onclick="() => { StopSecurityAutoRefresh(); _adminTab = 4; _ = LoadGalleryIfNeeded(); }">
            <i class="bi bi-images"></i> 갤러리
        </button>
        <button class="admin-tab @(_adminTab == 1 ? "active" : "")" @onclick="() => { StopSecurityAutoRefresh(); _adminTab = 1; }">
            <i class="bi bi-shop"></i> 매장
        </button>
        <button class="admin-tab @(_adminTab == 3 ? "active" : "")" @onclick="OpenSecurityTab">
            <i class="bi bi-shield-lock"></i> 보안
        </button>
        @if (_shopConfig.CalendarEnabled)
        {
            <button class="admin-tab" @onclick="GoToCalendarEditor">
                <i class="bi bi-palette"></i> 다꾸
            </button>
        }
    </div>

    @if (_adminTab == 0)
    {
        <!-- 스타일/B·A 서브탭 -->
        <div class="admin-sub-tab-bar">
            <button class="admin-sub-tab @(_styleSubTab == 0 ? "active" : "")" @onclick="() => _styleSubTab = 0">
                <i class="bi bi-grid"></i> 스타일 관리
            </button>
            <button class="admin-sub-tab" @onclick="GoToBAEditor">
                <i class="bi bi-arrow-left-right"></i> Before / After
            </button>
        </div>

        @if (_styleSubTab == 0)
        {
        <!-- 스타일 관리 탭 -->
        <div class="admin-header">
            <h2 class="admin-title">스타일 관리</h2>
            <div class="admin-actions">
                <a href="admin/edit" class="btn btn-salon">
                    <i class="bi bi-plus-lg"></i> 새 스타일
                </a>
                @if (!_loading)
                {
                    <button class="btn btn-salon-outline" @onclick="SeedInitialData" disabled="@_seeding">
                        @if (_seeding)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                            <span>@_seedProgress / @_seedTotal</span>
                        }
                        else
                        {
                            <i class="bi bi-database-add"></i> @(_styles.Any() ? "데이터 초기화" : "초기 데이터 생성")
                        }
                    </button>
                }
            </div>
        </div>

        <!-- 검색 -->
        <div class="admin-search-bar">
            <div class="admin-search-wrap">
                <i class="bi bi-search"></i>
                <input type="text" class="admin-search-input" placeholder="제목, 해시태그 검색..."
                       @bind="_searchText" @bind:event="oninput" />
                @if (!string.IsNullOrEmpty(_searchText))
                {
                    <button class="admin-search-clear" @onclick="() => _searchText = string.Empty">
                        <i class="bi bi-x-circle-fill"></i>
                    </button>
                }
            </div>
            <button class="btn btn-sm @(_publishFilter == null ? "btn-outline-secondary" : _publishFilter == true ? "btn-success" : "btn-outline-danger") publish-filter-btn"
                    @onclick="TogglePublishFilter">
                <i class="bi @(_publishFilter == null ? "bi-funnel" : _publishFilter == true ? "bi-eye-fill" : "bi-eye-slash")"></i>
                @(_publishFilter == null ? "전체" : _publishFilter == true ? "게시" : "미게시")
            </button>
            <span class="admin-search-count">@FilteredStyles.Count()건</span>
        </div>

        @if (_loading)
        {
            <div class="text-center py-5">
                <div class="spinner-border spinner-border-sm"></div>
            </div>
        }
        else
        {
            @if (_selectedIds.Any())
            {
                <div class="bulk-toolbar">
                    <span class="bulk-count"><i class="bi bi-check2-square"></i> @(_selectedIds.Count)건 선택</span>
                    <button class="btn btn-sm bulk-btn bulk-publish" @onclick="() => BulkPublish(true)" disabled="@_bulkProcessing">
                        <i class="bi bi-check-circle"></i> 일괄 게시
                    </button>
                    <button class="btn btn-sm bulk-btn bulk-unpublish" @onclick="() => BulkPublish(false)" disabled="@_bulkProcessing">
                        <i class="bi bi-dash-circle"></i> 일괄 비게시
                    </button>
                    <button class="btn btn-sm bulk-btn bulk-delete" @onclick="BulkDelete" disabled="@_bulkProcessing">
                        <i class="bi bi-trash"></i> 일괄 삭제
                    </button>
                    <button class="btn btn-sm bulk-btn bulk-cancel" @onclick="() => _selectedIds.Clear()">
                        <i class="bi bi-x-lg"></i> 취소
                    </button>
                </div>
            }
            <div class="table-responsive">
                <table class="table admin-table">
                    <thead>
                        <tr>
                            <th style="width:36px"><input type="checkbox" checked="@IsAllSelected" @onchange="() => ToggleSelectAll()" class="form-check-input" /></th>
                            <th class="sortable-th" @onclick='() => ToggleSort("title")'>제목 @SortIcon("title")</th>
                            <th class="sortable-th" @onclick='() => ToggleSort("images")'>사진 @SortIcon("images")</th>
                            <th class="sortable-th" @onclick='() => ToggleSort("category")'>카테고리 @SortIcon("category")</th>
                            <th class="sortable-th" @onclick='() => ToggleSort("published")'>게시 @SortIcon("published")</th>
                            <th>배지</th>
                            <th class="sortable-th" @onclick='() => ToggleSort("date")'>생성일 @SortIcon("date")</th>
                            <th>관리</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!FilteredStyles.Any())
                        {
                            <tr>
                                <td colspan="8" class="text-center text-muted py-4">
                                    @(string.IsNullOrEmpty(_searchText) ? "등록된 스타일이 없습니다." : "검색 결과가 없습니다.")
                                </td>
                            </tr>
                        }
                        @foreach (var style in FilteredStyles)
                        {
                            <tr class="@(_selectedIds.Contains(style.Id) ? "row-selected" : "")">
                                <td><input type="checkbox" checked="@_selectedIds.Contains(style.Id)" @onchange="() => ToggleSelect(style.Id)" class="form-check-input" /></td>
                                <td>@style.Title</td>
                                <td class="text-center">
                                    @if (style.ImageUrls.Count > 0)
                                    {
                                        <span class="badge-img-count"><i class="bi bi-image"></i> @style.ImageUrls.Count</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">0</span>
                                    }
                                </td>
                                <td><span class="badge-category">@style.Category.ToFullName()</span></td>
                                <td>
                                    <button class="btn btn-sm admin-publish-toggle @(style.IsPublished ? "published" : "unpublished")"
                                            @onclick="() => TogglePublish(style)">
                                        <i class="bi @(style.IsPublished ? "bi-check-circle-fill" : "bi-dash-circle")"></i>
                                        @(style.IsPublished ? "게시" : "비게시")
                                    </button>
                                </td>
                                <td>
                                    <div class="badge-toggle-group">
                                        <button class="btn btn-sm badge-toggle @(style.IsSignature ? "active-signature" : "")"
                                                @onclick="() => ToggleSignature(style)" title="시그니처">
                                            <i class="bi bi-award-fill"></i>
                                        </button>
                                        <button class="btn btn-sm badge-toggle @(style.IsFeatured ? "active-featured" : "")"
                                                @onclick="() => ToggleFeatured(style)" title="인기">
                                            <i class="bi bi-fire"></i>
                                        </button>
                                    </div>
                                </td>
                                <td>@style.CreatedAt.ToString("yyyy.MM.dd")</td>
                                <td>
                                    <div class="admin-action-btns">
                                        @if (style.Service != ServiceType.염색)
                                        {
                                            <button class="btn btn-sm admin-action-btn btn-outline-secondary" @onclick="() => ShowPrompt(style)" title="AI 프롬프트">
                                                <i class="bi bi-stars"></i>
                                            </button>
                                        }
                                        <a href="admin/edit/@style.Id" class="btn btn-sm admin-action-btn btn-salon-outline">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <button class="btn btn-sm admin-action-btn btn-outline-danger" @onclick="() => DeleteStyle(style)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    }
    }
    else if (_adminTab == 1)
    {
        <!-- 매장 관리 탭 -->
        <div class="admin-header">
            <h2 class="admin-title">매장 관리</h2>
        </div>

        <!-- 매장 서브탭 -->
        <div class="shop-sub-tab-bar">
            <button class="shop-sub-tab @(_shopAdminTab == 0 ? "active" : "")" @onclick="() => _shopAdminTab = 0">
                <i class="bi bi-wifi"></i> 기본정보
            </button>
            <button class="shop-sub-tab @(_shopAdminTab == 1 ? "active" : "")" @onclick="() => _shopAdminTab = 1">
                <i class="bi bi-share"></i> SNS
            </button>
            <button class="shop-sub-tab @(_shopAdminTab == 2 ? "active" : "")" @onclick="() => _shopAdminTab = 2">
                <i class="bi bi-question-circle"></i> FAQ
            </button>
            <button class="shop-sub-tab @(_shopAdminTab == 3 ? "active" : "")" @onclick="() => _shopAdminTab = 3">
                <i class="bi bi-check2-square"></i> 마감
            </button>
            <button class="shop-sub-tab @(_shopAdminTab == 4 ? "active" : "")" @onclick="() => _shopAdminTab = 4">
                <i class="bi bi-trash3"></i> 기타
            </button>
            <button class="shop-sub-tab @(_shopAdminTab == 5 ? "active" : "")" @onclick="() => _shopAdminTab = 5">
                <i class="bi bi-speedometer2"></i> 최적화
            </button>
        </div>

        @if (_shopAdminTab == 0)
        {
            <!-- WiFi 정보 -->
            <div class="shop-section">
                <div class="shop-section-header">
                    <i class="bi bi-wifi"></i>
                    <h3>WiFi 정보</h3>
                </div>
                <div class="shop-edit-grid">
                    <div class="shop-edit-group">
                        <label class="form-label">WiFi 5G 이름</label>
                        <input type="text" class="form-control form-control-sm" @bind="_shopConfig.WifiName5G" />
                    </div>
                    <div class="shop-edit-group">
                        <label class="form-label">WiFi 2.4G 이름</label>
                        <input type="text" class="form-control form-control-sm" @bind="_shopConfig.WifiName24G" />
                    </div>
                    <div class="shop-edit-group">
                        <label class="form-label">WiFi 비밀번호</label>
                        <input type="text" class="form-control form-control-sm" @bind="_shopConfig.WifiPassword" />
                    </div>
                </div>
            </div>

            <!-- 계좌 정보 -->
            <div class="shop-section" style="margin-top: 1rem;">
                <div class="shop-section-header">
                    <i class="bi bi-credit-card"></i>
                    <h3>계좌 정보</h3>
                </div>
                <div class="shop-edit-grid">
                    <div class="shop-edit-group">
                        <label class="form-label">은행</label>
                        <input type="text" class="form-control form-control-sm" @bind="_shopConfig.BankName" />
                    </div>
                    <div class="shop-edit-group">
                        <label class="form-label">계좌번호</label>
                        <input type="text" class="form-control form-control-sm" @bind="_shopConfig.AccountNumber" />
                    </div>
                    <div class="shop-edit-group">
                        <label class="form-label">예금주</label>
                        <input type="text" class="form-control form-control-sm" @bind="_shopConfig.AccountHolder" />
                    </div>
                </div>
            </div>

            <!-- 간편결제 -->
            <div class="shop-section" style="margin-top: 1rem;">
                <div class="shop-section-header">
                    <i class="bi bi-phone"></i>
                    <h3>간편결제</h3>
                </div>

                <div class="sns-admin-item">
                    <div class="sns-admin-toggle">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" @bind="_shopConfig.KakaoPayEnabled" id="kakaoPay" />
                            <label class="form-check-label fw-bold" for="kakaoPay">
                                <i class="bi bi-chat-dots-fill" style="color:#FEE500"></i> 카카오페이
                            </label>
                        </div>
                    </div>
                    <div class="shop-edit-group mt-1">
                        <input type="text" class="form-control form-control-sm" @bind="_shopConfig.KakaoPayUrl"
                               placeholder="카카오페이 송금 링크 URL" />
                    </div>
                </div>

                <div class="sns-admin-item">
                    <div class="sns-admin-toggle">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" @bind="_shopConfig.NaverPayEnabled" id="naverPay" />
                            <label class="form-check-label fw-bold" for="naverPay">
                                <span class="naver-n" style="font-size:0.75rem">N</span> 네이버페이
                            </label>
                        </div>
                    </div>
                    <div class="shop-edit-group mt-1">
                        <input type="text" class="form-control form-control-sm" @bind="_shopConfig.NaverPayUrl"
                               placeholder="네이버페이 결제 링크 URL" />
                    </div>
                </div>

            </div>

            <!-- 기능 설정 -->
            <div class="shop-section" style="margin-top: 1rem;">
                <div class="shop-section-header">
                    <i class="bi bi-toggles"></i>
                    <h3>기능 설정</h3>
                </div>
                <div class="sns-admin-item">
                    <div class="sns-admin-toggle">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" @bind="_shopConfig.CalendarEnabled" id="calendarEnabled" />
                            <label class="form-check-label fw-bold" for="calendarEnabled">
                                <i class="bi bi-palette" style="color:#e91e63"></i> 다꾸 캘린더
                            </label>
                        </div>
                    </div>
                    <small class="text-secondary">활성화하면 메인 탭에 다꾸 캘린더가 표시됩니다</small>
                </div>
            </div>

            <button class="btn btn-salon mt-3" @onclick="SaveShopConfig" disabled="@_shopSaving">
                @if (_shopSaving)
                {
                    <span class="spinner-border spinner-border-sm me-1"></span>
                }
                @if (_shopSaved)
                {
                    <span class="badge bg-success me-1">저장됨</span>
                }
                <i class="bi bi-check-lg"></i> 저장
            </button>
        }
        else if (_shopAdminTab == 1)
        {
            <!-- SNS 관리 -->
            <div class="shop-section">
                <div class="shop-section-header">
                    <i class="bi bi-share"></i>
                    <h3>SNS 관리</h3>
                </div>

                <!-- Instagram -->
                <div class="sns-admin-item">
                    <div class="sns-admin-toggle">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" @bind="_shopConfig.SnsInstagramEnabled" id="snsInstagram" />
                            <label class="form-check-label fw-bold" for="snsInstagram">
                                <i class="bi bi-instagram" style="color:#E1306C"></i> Instagram
                            </label>
                        </div>
                    </div>
                    <div class="shop-edit-group mt-1">
                        <input type="text" class="form-control form-control-sm" @bind="_shopConfig.InstagramUrl"
                               placeholder="https://www.instagram.com/yourshop" />
                    </div>
                </div>

                <!-- 카카오톡 채널 -->
                <div class="sns-admin-item">
                    <div class="sns-admin-toggle">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" @bind="_shopConfig.SnsKakaoEnabled" id="snsKakao" />
                            <label class="form-check-label fw-bold" for="snsKakao">
                                <i class="bi bi-chat-dots-fill" style="color:#FEE500"></i> 카카오톡 채널
                            </label>
                        </div>
                    </div>
                    <div class="shop-edit-group mt-1">
                        <input type="text" class="form-control form-control-sm" @bind="_shopConfig.KakaoChannelUrl"
                               placeholder="https://pf.kakao.com/yourshop" />
                    </div>
                </div>

                <!-- 네이버 플레이스 -->
                <div class="sns-admin-item">
                    <div class="sns-admin-toggle">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" @bind="_shopConfig.SnsNaverPlaceEnabled" id="snsNaverPlace" />
                            <label class="form-check-label fw-bold" for="snsNaverPlace">
                                <span style="color:#03C75A;font-weight:900">N</span> 네이버 플레이스
                            </label>
                        </div>
                    </div>
                    <div class="shop-edit-grid mt-1">
                        <div class="shop-edit-group">
                            <label class="form-label">플레이스 ID</label>
                            <input type="text" class="form-control form-control-sm" @bind="_shopConfig.NaverPlaceId"
                                   placeholder="1883331965" />
                        </div>
                        <div class="shop-edit-group">
                            <label class="form-label">검색어</label>
                            <input type="text" class="form-control form-control-sm" @bind="_shopConfig.NaverSearchKeyword"
                                   placeholder="산척동 미용실" />
                        </div>
                    </div>
                </div>

                <!-- 네이버 리뷰 -->
                <div class="sns-admin-item">
                    <div class="sns-admin-toggle">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" @bind="_shopConfig.SnsNaverReviewEnabled" id="snsNaverReview" />
                            <label class="form-check-label fw-bold" for="snsNaverReview">
                                <i class="bi bi-chat-heart" style="color:#ff6b6b"></i> 네이버 리뷰
                            </label>
                        </div>
                    </div>
                </div>

                <button class="btn btn-salon mt-2" @onclick="SaveShopConfig" disabled="@_shopSaving">
                    @if (_shopSaving)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                    }
                    <i class="bi bi-check-lg"></i> 저장
                </button>
            </div>
        }
        else if (_shopAdminTab == 2)
        {
            @if (_faqEditing != null)
            {
                <!-- FAQ 편집 화면 -->
                <div class="shop-section">
                    <div class="shop-section-header">
                        <button class="btn btn-sm btn-outline-secondary me-2" @onclick="CloseFaqEditor">
                            <i class="bi bi-arrow-left"></i>
                        </button>
                        <h3>@(_faqIsNew ? "FAQ 추가" : "FAQ 수정")</h3>
                    </div>
                    <div class="faq-edit-form">
                        <div class="mb-3">
                            <label class="form-label fw-bold">카테고리</label>
                            <input type="text" class="form-control form-control-sm" @bind="_faqEditing.Category"
                                   list="faqCategories" placeholder="예: 네이버 플레이스, 톡톡 파트너스, 카카오 채널" />
                            <datalist id="faqCategories">
                                <option value="네이버 플레이스" />
                                <option value="톡톡 파트너스" />
                                <option value="카카오 채널" />
                                <option value="토스 결제" />
                                <option value="매장 운영" />
                            </datalist>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">제목</label>
                            <input type="text" class="form-control" @bind="_faqEditing.Title" placeholder="예: 휴무일 설정 방법" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">상세 설명</label>
                            <RichTextEditor @bind-Value="_faqEditing.Description" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">스크린샷 / 이미지 (@(_faqEditing.ImageUrls.Count)장)</label>
                            @if (_faqEditing.ImageUrls.Any())
                            {
                                <div class="d-flex flex-wrap gap-2 mb-2">
                                    @for (int i = 0; i < _faqEditing.ImageUrls.Count; i++)
                                    {
                                        var idx = i;
                                        <div style="position:relative; width:80px; height:80px;">
                                            <img src="@_faqEditing.ImageUrls[idx]" style="width:100%; height:100%; object-fit:cover; border-radius:6px;" />
                                            <button class="btn btn-sm" style="position:absolute; top:-4px; right:-4px; background:rgba(220,53,69,0.85); color:#fff; border-radius:50%; width:20px; height:20px; padding:0; font-size:0.6rem; display:flex; align-items:center; justify-content:center;"
                                                    @onclick="() => RemoveFaqImage(idx)"><i class="bi bi-x"></i></button>
                                        </div>
                                    }
                                </div>
                            }
                            <InputFile OnChange="OnFaqImageSelected" multiple accept="image/*" class="form-control form-control-sm" />
                            @if (_faqUploading)
                            {
                                <div class="mt-1 text-muted small">
                                    <span class="spinner-border spinner-border-sm me-1"></span> 업로드 중...
                                </div>
                            }
                        </div>
                        <div class="row mb-3">
                            <div class="col-6">
                                <label class="form-label fw-bold">순서</label>
                                <input type="number" class="form-control form-control-sm" @bind="_faqEditing.Order" min="0" />
                            </div>
                            <div class="col-6 d-flex align-items-end">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" @bind="_faqEditing.IsPublished" id="faqPublished" />
                                    <label class="form-check-label" for="faqPublished">게시</label>
                                </div>
                            </div>
                        </div>
                        <div class="d-flex gap-2">
                            <button class="btn btn-secondary" @onclick="CloseFaqEditor">취소</button>
                            <button class="btn btn-salon" @onclick="SaveFaq" disabled="@(_faqSaving || string.IsNullOrWhiteSpace(_faqEditing.Title))">
                                @if (_faqSaving)
                                {
                                    <span class="spinner-border spinner-border-sm me-1"></span>
                                }
                                <i class="bi bi-check-lg"></i> 저장
                            </button>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <!-- FAQ 목록 (아코디언) -->
                <div class="shop-section">
                    <div class="shop-section-header">
                        <i class="bi bi-question-circle"></i>
                        <h3>FAQ 관리</h3>
                        <span class="text-muted ms-2" style="font-size:0.8rem">@(_faqItems.Count)건</span>
                        <button class="btn btn-salon btn-sm ms-auto" @onclick="ShowFaqEditor">
                            <i class="bi bi-plus-lg"></i> 추가
                        </button>
                    </div>

                    <!-- FAQ 카테고리 탭 -->
                    @{
                        var faqCategories = _faqItems.Select(f => f.Category).Where(c => !string.IsNullOrEmpty(c)).Distinct().OrderBy(c => c).ToList();
                    }
                    @if (faqCategories.Any())
                    {
                        <div class="faq-category-tabs">
                            <button class="faq-cat-tab @(_faqCategoryFilter == "전체" ? "active" : "")"
                                    @onclick='() => _faqCategoryFilter = "전체"'>
                                전체 <span class="faq-cat-count">@(_faqItems.Count)</span>
                            </button>
                            @foreach (var cat in faqCategories)
                            {
                                <button class="faq-cat-tab @(_faqCategoryFilter == cat ? "active" : "")"
                                        @onclick="() => _faqCategoryFilter = cat">
                                    <span class="faq-cat-dot" style="background:@GetFaqCategoryColor(cat);"></span>
                                    @cat
                                    <span class="faq-cat-count">@(_faqItems.Count(f => f.Category == cat))</span>
                                </button>
                            }
                        </div>
                    }

                    @if (_faqLoading)
                    {
                        <div class="text-center py-3">
                            <div class="spinner-border spinner-border-sm"></div>
                        </div>
                    }
                    else if (!_faqItems.Any())
                    {
                        <div class="text-center text-muted py-3">
                            <i class="bi bi-info-circle"></i> 등록된 FAQ가 없습니다
                        </div>
                    }
                    else
                    {
                        @foreach (var faq in FilteredFaqItems)
                            {
                                <div class="faq-acc-item @(_expandedFaqId == faq.Id ? "expanded" : "")"
                                     style="@GetFaqCategoryStyle(faq.Category)">
                                    <div class="faq-acc-header" @onclick="() => ToggleFaqAccordion(faq.Id)">
                                        <div class="faq-acc-title">
                                            @faq.Title
                                            @if (!faq.IsPublished)
                                            {
                                                <span class="badge bg-secondary ms-1" style="font-size:0.6rem">비공개</span>
                                            }
                                        </div>
                                        <i class="bi @(_expandedFaqId == faq.Id ? "bi-chevron-up" : "bi-chevron-down") faq-acc-chevron"></i>
                                    </div>
                                    @if (_expandedFaqId == faq.Id)
                                    {
                                        <div class="faq-acc-body">
                                            @if (faq.ImageUrls.Any())
                                            {
                                                <div class="faq-acc-images">
                                                    @foreach (var imgUrl in faq.ImageUrls)
                                                    {
                                                        <div class="faq-acc-image">
                                                            <img src="@imgUrl" alt="@faq.Title" />
                                                        </div>
                                                    }
                                                </div>
                                            }
                                            <div class="faq-acc-desc">@((MarkupString)HairSalonStyleBook.Services.HtmlSanitizer.Sanitize(faq.Description ?? ""))</div>
                                            <div class="faq-acc-actions">
                                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => EditFaq(faq)">
                                                    <i class="bi bi-pencil"></i> 수정
                                                </button>
                                                <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteFaq(faq)">
                                                    <i class="bi bi-trash"></i> 삭제
                                                </button>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                    }
                </div>
            }
        }
        else if (_shopAdminTab == 3)
        {
            <!-- 마감 체크리스트 (매장 서브탭) -->
            <div class="shop-section">
                <div class="shop-section-header">
                    <i class="bi bi-check2-square"></i>
                    <h3>마감 체크리스트</h3>
                    <span class="checklist-date ms-auto" style="font-size:0.75rem;">
                        <i class="bi bi-calendar3"></i> @DateTime.Now.ToString("MM.dd (ddd)")
                    </span>
                    <button class="btn btn-salon-outline btn-sm ms-1" @onclick="ResetChecklist">
                        <i class="bi bi-arrow-counterclockwise"></i>
                    </button>
                </div>

                <div class="checklist-container">
                    @foreach (var group in _checklistGroups)
                    {
                        <div class="checklist-group">
                            <div class="checklist-group-header">
                                <i class="bi @group.Icon" style="color: @group.Color;"></i>
                                <span>@group.Name</span>
                            </div>
                            @foreach (var item in group.Items)
                            {
                                <div class="checklist-item @(item.Checked ? "checked" : "")" @onclick="() => ToggleCheck(item)">
                                    <div class="checklist-checkbox">
                                        <i class="bi @(item.Checked ? "bi-check-square-fill" : "bi-square")"></i>
                                    </div>
                                    <span class="checklist-text">@item.Text</span>
                                </div>
                            }
                        </div>
                    }
                </div>

                <div class="checklist-progress">
                    <div class="progress-bar-wrap">
                        <div class="progress-bar-fill" style="width: @ChecklistProgress%"></div>
                    </div>
                    <span class="progress-text">@CheckedCount / @TotalCount 완료</span>
                </div>
            </div>
        }
        else if (_shopAdminTab == 4)
        {
            <!-- 쓰레기 배출일 안내 -->
            <div class="shop-section">
                <div class="shop-section-header">
                    <i class="bi bi-trash3"></i>
                    <h3>쓰레기 배출일 안내</h3>
                    <span class="shop-section-sub">화성시 동탄 산척동</span>
                </div>

                <div class="trash-schedule">
                    @foreach (var item in _trashSchedule)
                    {
                        <div class="trash-item">
                            <div class="trash-icon" style="background: @item.Color;">
                                <i class="bi @item.Icon"></i>
                            </div>
                            <div class="trash-info">
                                <span class="trash-type">@item.Type</span>
                                <span class="trash-days">@item.Days</span>
                            </div>
                            <div class="trash-time">@item.Time</div>
                        </div>
                    }
                </div>

                <div class="trash-notes">
                    <p><i class="bi bi-info-circle"></i> 공휴일에는 수거하지 않습니다</p>
                    <p><i class="bi bi-telephone"></i> 문의: 화성시 자원순환과 031-5189-6801</p>
                </div>
            </div>
        }
        else if (_shopAdminTab == 5)
        {
            <!-- 이미지 최적화 -->
            <div class="shop-section">
                <div class="shop-section-header">
                    <i class="bi bi-speedometer2"></i>
                    <h3>이미지 일괄 최적화</h3>
                </div>

                <p class="opt-desc">모든 컬렉션(스타일, 갤러리, B/A)의 이미지를 WebP로 재변환하고 리사이즈합니다.</p>

                @if (!_optimizing)
                {
                    <div class="opt-actions">
                        <button class="btn btn-salon" @onclick="ScanAndOptimize" disabled="@_optScanning">
                            @if (_optScanning)
                            {
                                <span class="spinner-border spinner-border-sm me-1"></span>
                            }
                            <i class="bi bi-search"></i> 스캔 및 최적화 시작
                        </button>
                        @if (_optScanResult != null)
                        {
                            <span class="opt-scan-result">@_optScanResult</span>
                        }
                    </div>
                }
                else
                {
                    <div class="opt-progress">
                        <div class="progress" style="height: 8px;">
                            <div class="progress-bar bg-success" style="width: @(_optTotal > 0 ? (int)(_optDone * 100.0 / _optTotal) : 0)%"></div>
                        </div>
                        <span class="opt-progress-text">@_optDone / @_optTotal 처리 중...</span>
                        @if (!string.IsNullOrEmpty(_optCurrentFile))
                        {
                            <span class="opt-current-file">@_optCurrentFile</span>
                        }
                    </div>
                }

                @if (!string.IsNullOrEmpty(_optResult))
                {
                    <div class="alert alert-success mt-3 py-2" style="font-size:0.85rem;">@_optResult</div>
                }
                @if (!string.IsNullOrEmpty(_optError))
                {
                    <div class="alert alert-danger mt-3 py-2" style="font-size:0.85rem;">@_optError</div>
                }
            </div>
        }

    }
    else if (_adminTab == 3)
    {
        <!-- 보안 탭 -->
        <div class="admin-header">
            <h2 class="admin-title">보안</h2>
        </div>

        <!-- 서브 탭 -->
        <div class="security-sub-tabs">
            <button class="security-sub-tab @(_securitySubTab == 0 ? "active" : "")" @onclick="() => _securitySubTab = 0">
                <i class="bi bi-clock-history"></i> 감사 로그
            </button>
            <button class="security-sub-tab @(_securitySubTab == 1 ? "active" : "")" @onclick="() => _securitySubTab = 1">
                <i class="bi bi-shield-lock"></i> 로그인 보안
            </button>
        </div>

        @if (_securitySubTab == 0)
        {
            <!-- 감사 로그 -->
            @if (_auditLoading)
            {
                <div class="text-center py-4">
                    <div class="spinner-border spinner-border-sm"></div>
                </div>
            }
            else if (!_auditLogs.Any())
            {
                <p class="text-muted text-center py-4" style="font-size:0.85rem;">감사 로그가 없습니다.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table admin-table">
                        <thead>
                            <tr>
                                <th>시간</th>
                                <th>액션</th>
                                <th>대상</th>
                                <th>상세</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var log in _auditLogs)
                            {
                                <tr>
                                    <td class="text-nowrap">@log.Timestamp.ToLocalTime().ToString("yyyy.MM.dd HH:mm")</td>
                                    <td>
                                        <span class="audit-badge audit-@log.Action.ToLower()">@GetAuditActionLabel(log.Action)</span>
                                    </td>
                                    <td>@log.TargetTitle</td>
                                    <td class="text-muted">@log.Details</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        }
        else
        {
            <!-- 로그인 보안 -->
            <div class="d-flex justify-content-end mb-3 align-items-center gap-2">
                <span class="text-muted" style="font-size:0.75rem;">
                    @if (_securityLoading)
                    {
                        <span class="spinner-border spinner-border-sm me-1" style="width:0.7rem;height:0.7rem;"></span>
                    }
                    else
                    {
                        <i class="bi bi-arrow-repeat text-success"></i>
                    }
                    @(SecurityRefreshIntervalSeconds)초 자동 새로고침
                </span>
            </div>

            @if (_blockedDevices.Any())
            {
                <div class="security-blocked-section">
                    <h6><i class="bi bi-shield-x"></i> 차단된 기기 (@_blockedDevices.Count)</h6>
                    <div class="security-blocked-list">
                        @foreach (var fp in _blockedDevices)
                        {
                            <div class="security-blocked-item">
                                <code>@fp</code>
                                <button class="btn btn-sm btn-outline-success" @onclick="() => UnblockDevice(fp)">
                                    <i class="bi bi-unlock"></i> 해제
                                </button>
                            </div>
                        }
                    </div>
                </div>
            }

            <div class="security-attempts-section">
                <h6><i class="bi bi-clock-history"></i> 최근 로그인 시도</h6>
                @if (!_loginAttempts.Any() && !_securityLoading)
                {
                    <p class="text-muted" style="font-size:0.85rem;">기록된 로그인 시도가 없습니다.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table admin-table security-table">
                            <thead>
                                <tr>
                                    <th>시간</th>
                                    <th>기기</th>
                                    <th>해상도</th>
                                    <th>결과</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var attempt in _loginAttempts)
                                {
                                    var isBlocked = _blockedDevices.Contains(attempt.DeviceFingerprint);
                                    <tr class="@(attempt.Success ? "" : "attempt-fail") @(isBlocked ? "attempt-blocked" : "")">
                                        <td>@attempt.Timestamp.ToLocalTime().ToString("MM/dd HH:mm")</td>
                                        <td>
                                            <span class="device-info">@attempt.DeviceInfo</span>
                                            <code class="device-fp">@attempt.DeviceFingerprint</code>
                                        </td>
                                        <td>@attempt.ScreenSize</td>
                                        <td>
                                            @if (attempt.Success)
                                            {
                                                <span class="badge bg-success">성공</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger">실패</span>
                                            }
                                        </td>
                                        <td>
                                            @if (!attempt.Success && !isBlocked)
                                            {
                                                <button class="btn btn-sm btn-outline-danger" @onclick="() => BlockDevice(attempt.DeviceFingerprint)">
                                                    <i class="bi bi-shield-x"></i> 차단
                                                </button>
                                            }
                                            else if (isBlocked)
                                            {
                                                <span class="badge bg-secondary">차단됨</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        }
    }
    else if (_adminTab == 4)
    {
        <!-- 갤러리 관리 탭 -->
        <div class="admin-header">
            <h2 class="admin-title">갤러리</h2>
            <div class="admin-actions">
                <div class="gallery-filter-bar">
                    <button class="gallery-filter-chip @(_galleryPublishFilter == "" ? "active" : "")"
                            @onclick='() => _galleryPublishFilter = ""'>전체 @(_galleryItems.Count)</button>
                    <button class="gallery-filter-chip @(_galleryPublishFilter == "published" ? "active" : "")"
                            @onclick='() => _galleryPublishFilter = "published"'>
                        <i class="bi bi-eye-fill"></i> 노출 @(_galleryItems.Count(g => g.IsPublished))
                    </button>
                    <button class="gallery-filter-chip @(_galleryPublishFilter == "hidden" ? "active" : "")"
                            @onclick='() => _galleryPublishFilter = "hidden"'>
                        <i class="bi bi-eye-slash"></i> 비노출 @(_galleryItems.Count(g => !g.IsPublished))
                    </button>
                </div>
            </div>
        </div>

        <!-- 업로드 영역 -->
        <div class="gallery-upload-area">
            <InputFile OnChange="OnGalleryFilesSelected" multiple accept="image/*"
                       class="gallery-upload-input" id="galleryUpload" />
            <label for="galleryUpload" class="gallery-upload-label">
                <i class="bi bi-cloud-arrow-up"></i>
                <span>사진을 클릭하여 업로드</span>
                <small>JPG, PNG, WebP / 최대 5MB / 여러 장 가능</small>
            </label>
        </div>

        @if (_galleryUploading)
        {
            <div class="text-center py-2">
                <span class="spinner-border spinner-border-sm me-1"></span>
                <span style="font-size:0.8rem;">업로드 중... @_galleryUploadedCount/@_galleryTotalUploadCount</span>
            </div>
        }
        @if (_gallerySkippedCount > 0 && !_galleryUploading)
        {
            <div class="alert alert-warning py-1 px-2 mt-1" style="font-size:0.75rem;">
                <i class="bi bi-exclamation-triangle"></i> @(_gallerySkippedCount)개 파일이 5MB 초과로 건너뛰었습니다.
            </div>
        }

        <!-- 설명 입력 (업로드 시) -->
        <div class="mb-2">
            <input type="text" class="form-control form-control-sm" placeholder="사진 설명 (선택)"
                   @bind="_galleryUploadDesc" maxlength="100" />
        </div>

        <!-- 선택 모드 툴바 -->
        @if (_galleryItems.Any())
        {
            <div class="gallery-toolbar">
                <button class="btn btn-sm btn-outline-secondary" @onclick="ToggleGallerySelectAll">
                    <i class="bi @(_selectedGalleryIds.Count == _galleryItems.Count ? "bi-check-square-fill" : "bi-square")"></i>
                    전체
                </button>
                @if (_selectedGalleryIds.Any())
                {
                    <span class="text-muted" style="font-size: 0.75rem;">@(_selectedGalleryIds.Count)장</span>
                    <button class="btn btn-sm btn-salon" @onclick="OpenStyleSearchModal">
                        <i class="bi bi-arrow-right-square"></i> 스타일에 적용
                    </button>
                    <button class="btn btn-sm btn-outline-danger" @onclick="DeleteSelectedGallery">
                        <i class="bi bi-trash3"></i>
                    </button>
                }
            </div>
        }

        <!-- 사진 그리드 -->
        @if (!_galleryItems.Any() && !_galleryUploading)
        {
            <div class="text-center text-muted py-4" style="font-size:0.85rem;">갤러리에 사진이 없습니다.</div>
        }
        else
        {
            <div class="gallery-admin-grid">
                @foreach (var item in FilteredAdminGalleryItems)
                {
                    <div class="gallery-admin-card @(_selectedGalleryIds.Contains(item.Id) ? "selected" : "")"
                         @onclick="() => ToggleGallerySelect(item.Id)">
                        <div class="frame-@item.Decoration.FrameType" style="width:100%;height:100%;position:relative;">
                            <img src="@item.ImageUrl" alt="@item.Description" loading="lazy" />
                            @if (!string.IsNullOrEmpty(item.Decoration.TextContent))
                            {
                                <div class="gd-free-text gd-font-@item.Decoration.TextFont"
                                     style="left:@AFPct(item.Decoration.TextX);top:@AFPct(item.Decoration.TextY);color:@item.Decoration.TextColor;transform:translate(-50%,-50%) scale(@AFScl(item.Decoration.TextScale * 0.5));font-size:0.6rem;">
                                    @item.Decoration.TextContent
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(item.Decoration.Sticker))
                            {
                                <div class="gd-free-sticker"
                                     style="left:@AFPct(item.Decoration.StickerX);top:@AFPct(item.Decoration.StickerY);transform:translate(-50%,-50%) scale(@AFScl(item.Decoration.StickerScale * 0.5));font-size:1rem;">
                                    @item.Decoration.Sticker
                                </div>
                            }
                        </div>
                        <div class="gallery-check">
                            <i class="bi @(_selectedGalleryIds.Contains(item.Id) ? "bi-check-circle-fill" : "bi-circle")"></i>
                        </div>
                        @if (!string.IsNullOrEmpty(item.Description))
                        {
                            <div class="gallery-admin-memo">@item.Description</div>
                        }
                        <button class="gallery-edit-btn" @onclick:stopPropagation @onclick="() => OpenAdminGalleryEdit(item)">
                            <i class="bi bi-palette"></i>
                        </button>
                        <button class="gallery-publish-btn @(item.IsPublished ? "" : "hidden-item")"
                                @onclick:stopPropagation @onclick="() => ToggleGalleryPublish(item)">
                            <i class="bi @(item.IsPublished ? "bi-eye-fill" : "bi-eye-slash")"></i>
                        </button>
                        <button class="gallery-lock-btn @(item.IsLocked ? "locked" : "")"
                                @onclick:stopPropagation @onclick="() => ToggleGalleryLock(item)">
                            <i class="bi @(item.IsLocked ? "bi-lock-fill" : "bi-unlock")"></i>
                        </button>
                        @if (!item.IsPublished)
                        {
                            <div class="gallery-hidden-badge">비노출</div>
                        }
                        @if (item.IsLocked)
                        {
                            <div class="gallery-locked-badge">잠금</div>
                        }
                    </div>
                }
            </div>
        }
    }
</div>

<!-- 스타일 검색 모달 (갤러리→스타일 적용) -->
@if (_showStyleSearchModal)
{
    <div class="modal-overlay" @onclick="CloseStyleSearchModal">
        <div class="style-search-modal" @onclick:stopPropagation>
            <div class="style-search-modal-header">
                <h5>스타일 선택</h5>
                <button class="btn-close" @onclick="CloseStyleSearchModal"></button>
            </div>
            <div class="style-search-modal-body">
                <!-- 앵글 선택 -->
                <div class="angle-select-row mb-2">
                    <span class="angle-select-label">앵글:</span>
                    @foreach (var ang in _galleryAngleOptions)
                    {
                        var a = ang;
                        <button class="angle-select-chip @(_galleryApplyAngle == a.Key ? "active" : "")"
                                @onclick="() => ToggleGalleryAngle(a.Key)">
                            @a.Value
                        </button>
                    }
                </div>
                <input type="text" class="form-control form-control-sm mb-2" placeholder="스타일 검색..."
                       @bind="_galleryStyleSearch" @bind:event="oninput" />
                <div class="style-search-results">
                    @foreach (var style in FilteredStylesForGallery)
                    {
                        <div class="style-search-item" @onclick="() => ApplyPhotosToStyle(style)">
                            @if (!string.IsNullOrEmpty(style.ThumbnailUrl))
                            {
                                <img src="@style.ThumbnailUrl" alt="" class="style-search-thumb" />
                            }
                            else
                            {
                                <div class="style-search-thumb-empty"><i class="bi bi-image"></i></div>
                            }
                            <div>
                                <div class="style-search-title">@style.Title</div>
                                <div class="style-search-meta">
                                    @style.Category.ToDisplayName() / @style.Service
                                    <span class="ms-1"><i class="bi bi-image"></i> @style.ImageUrls.Count</span>
                                </div>
                            </div>
                        </div>
                    }
                    @if (!FilteredStylesForGallery.Any())
                    {
                        <div class="text-center text-muted py-3" style="font-size:0.8rem;">검색 결과 없음</div>
                    }
                </div>
            </div>
        </div>
    </div>
}

<!-- 갤러리 편집 오버레이 (Admin) -->
@if (_adminGalleryEditItem != null)
{
    <div class="gallery-edit-overlay" @onclick="() => _adminGalleryEditItem = null">
        <div class="gallery-edit-panel" @onclick:stopPropagation>
            <div class="gallery-edit-header">
                <h5><i class="bi bi-palette"></i> 사진 꾸미기</h5>
                <button class="btn-close" @onclick="() => _adminGalleryEditItem = null"></button>
            </div>
            <div class="gallery-edit-body">
                <GalleryDecorator Item="_adminGalleryEditItem" EditMode="true"
                                  OnSave="SaveAdminGalleryDecoration"
                                  OnCancel="() => _adminGalleryEditItem = null" />
            </div>
        </div>
    </div>
}

<!-- AI 프롬프트 모달 -->
@if (_promptStyle != null)
{
    <div class="prompt-backdrop" @onclick="ClosePrompt"></div>
    <div class="prompt-modal">
        <div class="prompt-modal-header">
            <h3><i class="bi bi-stars"></i> AI 이미지 프롬프트</h3>
            <button class="btn-close" @onclick="ClosePrompt"></button>
        </div>
        <div class="prompt-modal-title">@_promptStyle.Title</div>
        <div class="prompt-modal-body">
            <div class="prompt-field">
                <label>모델 나이대</label>
                <div class="d-flex gap-2">
                    <select class="form-select form-select-sm" @bind="_promptAgeGroup">
                        <option>10대</option>
                        <option>20대</option>
                        <option>30대</option>
                        <option>40대</option>
                        <option>50대</option>
                    </select>
                    <select class="form-select form-select-sm" @bind="_promptAgeDetail">
                        <option>초반</option>
                        <option>중반</option>
                        <option>후반</option>
                    </select>
                </div>
            </div>
            <div class="prompt-field">
                <label>분위기</label>
                <select class="form-select form-select-sm" @bind="_promptMood">
                    <option>자연스러움</option>
                    <option>발랄함</option>
                    <option>섹시함</option>
                    <option>귀여움</option>
                    <option>시크함</option>
                    <option>청순함</option>
                    <option>세련됨</option>
                </select>
            </div>
            <div class="prompt-field">
                <label>촬영 앵글</label>
                <div class="prompt-angle-group">
                    @foreach (var angle in _angleOptions)
                    {
                        <button class="prompt-angle-btn @(_promptAngle == angle.key ? "active" : "")"
                                @onclick="() => _promptAngle = angle.key">
                            <i class="bi @angle.icon"></i> @angle.label
                        </button>
                    }
                </div>
            </div>
            <div class="prompt-ai-tabs">
                <button class="prompt-ai-tab @(_promptAi == "nanobanana" ? "active" : "")" @onclick='() => SelectAi("nanobanana")'>
                    나노바나나 Pro
                </button>
                <button class="prompt-ai-tab @(_promptAi == "gemini" ? "active" : "")" @onclick='() => SelectAi("gemini")'>
                    Gemini
                </button>
                <button class="prompt-ai-tab @(_promptAi == "chatgpt" ? "active" : "")" @onclick='() => SelectAi("chatgpt")'>
                    ChatGPT
                </button>
            </div>
            <div class="prompt-output">
                <div class="prompt-ai-link">
                    @if (_promptAi == "nanobanana")
                    {
                        <a href="https://nanobanana.com" target="_blank"><i class="bi bi-box-arrow-up-right"></i> nanobanana.com 열기</a>
                    }
                    else if (_promptAi == "gemini")
                    {
                        <a href="https://gemini.google.com" target="_blank"><i class="bi bi-box-arrow-up-right"></i> gemini.google.com 열기</a>
                    }
                    else
                    {
                        <a href="https://chatgpt.com" target="_blank"><i class="bi bi-box-arrow-up-right"></i> chatgpt.com 열기</a>
                    }
                </div>
                <div class="prompt-text" @onclick="CopyPrompt">@GetGeneratedPrompt()</div>
            </div>
            @if (_promptCopied)
            {
                <div class="prompt-copied"><i class="bi bi-check-circle-fill"></i> 복사됨</div>
            }
            <div class="prompt-filename">
                <i class="bi bi-file-image"></i> 저장 파일명:
                <code @onclick="CopyFilename">@GetSuggestedFilename()</code>
            </div>
        </div>
    </div>
}

<!-- Toast 알림 -->
@if (!string.IsNullOrEmpty(_toastMessage))
{
    <div class="admin-toast @(_toastVisible ? "show" : "")">
        <i class="bi bi-check-circle-fill"></i> @_toastMessage
    </div>
}


<style>
