@page "/before-after"
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@inject IBeforeAfterService BAService
@inject IAuthService AuthService
@inject NavigationManager Nav

<PageTitle>Before / After - 늘~오던 헤어살롱</PageTitle>

<div class="container ba-page">
    <div class="ba-page-header">
        <h2 class="ba-page-title"><i class="bi bi-arrow-left-right"></i> Before / After</h2>
        <p class="ba-page-sub">시술 전후 비교</p>
    </div>

    @* 카테고리 필터 *@
    <div class="ba-filter-bar">
        @foreach (var cat in _categories)
        {
            <button class="ba-filter-chip @(cat == _selectedCat ? "active" : "")"
                    @onclick="() => SelectCategory(cat)">
                @cat
            </button>
        }
    </div>

    @if (_loading)
    {
        <div class="ba-skeleton-grid">
            @for (int i = 0; i < 4; i++)
            {
                <div class="ba-skeleton-card">
                    <div class="ba-skeleton-img"></div>
                    <div class="ba-skeleton-text"></div>
                </div>
            }
        </div>
    }
    else if (!_items.Any())
    {
        <div class="ba-empty">
            <i class="bi bi-image" style="font-size: 3rem; opacity: 0.3;"></i>
            <p>등록된 Before/After가 없습니다.</p>
        </div>
    }
    else
    {
        <div class="ba-card-grid">
            @foreach (var item in _filtered)
            {
                <div class="ba-card" @onclick="() => OpenFullscreen(item)">
                    <BeforeAfterSlider BeforeImageUrls="item.BeforeImageUrls"
                                       AfterImageUrls="item.AfterImageUrls"
                                       Height="280" />
                    <div class="ba-card-body">
                        <h5 class="ba-card-title">@item.Title</h5>
                        @if (!string.IsNullOrWhiteSpace(item.Description))
                        {
                            <p class="ba-card-desc">@item.Description</p>
                        }
                        <div class="ba-card-meta">
                            @if (!string.IsNullOrWhiteSpace(item.Category))
                            {
                                <span class="ba-badge">@item.Category</span>
                            }
                            @foreach (var tag in item.Hashtags.Take(3))
                            {
                                <span class="ba-hashtag">#@tag</span>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (_hasMore)
        {
            <div class="text-center mt-3 mb-4">
                <button class="btn btn-salon-outline" @onclick="LoadMore" disabled="@_loadingMore">
                    @if (_loadingMore)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                    }
                    더보기
                </button>
            </div>
        }
    }

    @* 풀스크린 모달 *@
    @if (_fullscreenItem != null)
    {
        <div class="ba-fullscreen-overlay" @onclick="CloseFullscreen">
            <div class="ba-fullscreen-content" @onclick:stopPropagation="true">
                <button class="ba-fullscreen-close" @onclick="CloseFullscreen"><i class="bi bi-x-lg"></i></button>

                @if (_filtered.Count > 1)
                {
                    <button class="ba-fs-nav ba-fs-prev" @onclick="PrevItem"><i class="bi bi-chevron-left"></i></button>
                    <button class="ba-fs-nav ba-fs-next" @onclick="NextItem"><i class="bi bi-chevron-right"></i></button>
                }

                <BeforeAfterSlider BeforeImageUrls="_fullscreenItem.BeforeImageUrls"
                                   AfterImageUrls="_fullscreenItem.AfterImageUrls"
                                   Height="500" />

                <div class="ba-fs-info">
                    <h4>@_fullscreenItem.Title</h4>
                    @if (!string.IsNullOrWhiteSpace(_fullscreenItem.Description))
                    {
                        <p>@_fullscreenItem.Description</p>
                    }
                    <div class="ba-card-meta">
                        @if (!string.IsNullOrWhiteSpace(_fullscreenItem.Category))
                        {
                            <span class="ba-badge">@_fullscreenItem.Category</span>
                        }
                        @foreach (var tag in _fullscreenItem.Hashtags)
                        {
                            <span class="ba-hashtag">#@tag</span>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private readonly string[] _categories = { "전체", "남성", "여성숏", "여성단발", "여성미디움", "여성롱" };
    private string _selectedCat = "전체";

    private List<BeforeAfterItem> _items = new();
    private bool _loading = true;
    private bool _hasMore;
    private bool _loadingMore;
    private BeforeAfterItem? _fullscreenItem;

    private List<BeforeAfterItem> _filtered =>
        _selectedCat == "전체"
            ? _items
            : _items.Where(x => x.Category == _selectedCat).ToList();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var (items, hasMore) = await BAService.GetPageAsync(12, null, true);
            _items = items;
            _hasMore = hasMore;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[BeforeAfter] 로드 실패: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }

    private void SelectCategory(string cat)
    {
        _selectedCat = cat;
    }

    private async Task LoadMore()
    {
        if (_loadingMore || !_hasMore) return;
        _loadingMore = true;
        try
        {
            var lastDate = _items.LastOrDefault()?.CreatedAt;
            var (items, hasMore) = await BAService.GetPageAsync(12, lastDate, true);
            _items.AddRange(items);
            _hasMore = hasMore;
        }
        finally
        {
            _loadingMore = false;
        }
    }

    private void OpenFullscreen(BeforeAfterItem item) => _fullscreenItem = item;
    private void CloseFullscreen() => _fullscreenItem = null;

    private void PrevItem()
    {
        if (_fullscreenItem == null) return;
        var list = _filtered;
        var idx = list.IndexOf(_fullscreenItem);
        if (idx < 0) return;
        _fullscreenItem = list[(idx - 1 + list.Count) % list.Count];
    }

    private void NextItem()
    {
        if (_fullscreenItem == null) return;
        var list = _filtered;
        var idx = list.IndexOf(_fullscreenItem);
        if (idx < 0) return;
        _fullscreenItem = list[(idx + 1) % list.Count];
    }
}

<style>
    .ba-page {
        padding-bottom: 2rem;
    }

    .ba-page-header {
        text-align: center;
        padding: 1.5rem 0 0.5rem;
    }

    .ba-page-title {
        font-family: 'Noto Serif KR', serif;
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--text-primary, #1a1a1a);
    }

    .ba-page-sub {
        color: var(--text-secondary, #666);
        font-size: 0.85rem;
        margin: 0;
    }

    /* 카테고리 필터 */
    .ba-filter-bar {
        display: flex;
        gap: 6px;
        padding: 0.75rem 0;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
    }

    .ba-filter-chip {
        padding: 6px 14px;
        border: 1.5px solid var(--border-color, #ddd);
        border-radius: 20px;
        background: transparent;
        color: var(--text-secondary, #666);
        font-size: 0.8rem;
        white-space: nowrap;
        cursor: pointer;
        transition: all 0.2s;
    }

    .ba-filter-chip.active,
    .ba-filter-chip:hover {
        background: var(--text-primary, #1a1a1a);
        color: #fff;
        border-color: var(--text-primary, #1a1a1a);
    }

    /* 카드 그리드 */
    .ba-card-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.2rem;
    }

    @@media (min-width: 768px) {
        .ba-card-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    .ba-card {
        border-radius: 14px;
        overflow: hidden;
        background: var(--bg-primary, #fff);
        box-shadow: 0 2px 12px rgba(0,0,0,0.08);
        cursor: pointer;
        transition: transform 0.2s, box-shadow 0.2s;
    }

    .ba-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 6px 20px rgba(0,0,0,0.12);
    }

    .ba-card-body {
        padding: 0.8rem 1rem;
    }

    .ba-card-title {
        font-size: 1rem;
        font-weight: 600;
        margin-bottom: 0.3rem;
        color: var(--text-primary, #1a1a1a);
    }

    .ba-card-desc {
        font-size: 0.82rem;
        color: var(--text-secondary, #666);
        margin-bottom: 0.4rem;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .ba-card-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 5px;
        align-items: center;
    }

    .ba-badge {
        font-size: 0.7rem;
        padding: 2px 8px;
        border-radius: 10px;
        background: var(--bg-secondary, #f5f5f5);
        color: var(--text-secondary, #666);
    }

    .ba-hashtag {
        font-size: 0.72rem;
        color: #888;
    }

    /* 빈 상태 */
    .ba-empty {
        text-align: center;
        padding: 4rem 1rem;
        color: var(--text-secondary, #999);
    }

    /* 스켈레톤 */
    .ba-skeleton-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.2rem;
    }

    @@media (min-width: 768px) {
        .ba-skeleton-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    .ba-skeleton-card {
        border-radius: 14px;
        overflow: hidden;
        background: var(--bg-primary, #fff);
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    }

    .ba-skeleton-img {
        height: 280px;
        background: linear-gradient(110deg, #e8e8e8 25%, #f5f5f5 37%, #e8e8e8 63%);
        background-size: 200% 100%;
        animation: skeleton-shine 1.5s infinite;
    }

    .ba-skeleton-text {
        height: 40px;
        margin: 12px;
        border-radius: 6px;
        background: linear-gradient(110deg, #e8e8e8 25%, #f5f5f5 37%, #e8e8e8 63%);
        background-size: 200% 100%;
        animation: skeleton-shine 1.5s infinite;
    }

    @@keyframes skeleton-shine {
        0% { background-position: 200% 0; }
        100% { background-position: -200% 0; }
    }

    /* 풀스크린 모달 */
    .ba-fullscreen-overlay {
        position: fixed;
        inset: 0;
        z-index: 9999;
        background: rgba(0,0,0,0.85);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem;
    }

    .ba-fullscreen-content {
        position: relative;
        width: 100%;
        max-width: 700px;
        border-radius: 16px;
        overflow: hidden;
        background: var(--bg-primary, #fff);
    }

    .ba-fullscreen-close {
        position: absolute;
        top: 10px;
        right: 10px;
        z-index: 20;
        width: 36px;
        height: 36px;
        border: none;
        border-radius: 50%;
        background: rgba(0,0,0,0.5);
        color: #fff;
        font-size: 1rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .ba-fs-nav {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        z-index: 20;
        width: 40px;
        height: 40px;
        border: none;
        border-radius: 50%;
        background: rgba(0,0,0,0.4);
        color: #fff;
        font-size: 1.2rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .ba-fs-prev { left: 10px; }
    .ba-fs-next { right: 10px; }

    .ba-fs-info {
        padding: 1rem 1.2rem;
    }

    .ba-fs-info h4 {
        margin-bottom: 0.3rem;
        font-size: 1.1rem;
        font-weight: 600;
    }

    .ba-fs-info p {
        font-size: 0.85rem;
        color: var(--text-secondary, #666);
        margin-bottom: 0.5rem;
    }
</style>
